---
const pathname = Astro.url.pathname;
const isActive = (href: string): boolean => {
  if (href === '/') return pathname === '/' || pathname === '/index';
  return pathname.startsWith(href);
};
---

<nav
  style="background:linear-gradient(135deg,#060F1E 0%,#0A1F42 45%,#0D2860 100%);box-shadow:0 2px 20px rgba(0,0,0,.35);position:sticky;top:0;z-index:50;width:100%;overflow:visible;"
  aria-label="Navegación principal"
>
  <div style="max-width:80rem;margin:0 auto;padding:0 16px;">
    <div style="display:flex;align-items:center;justify-content:space-between;height:64px;gap:8px;">

      <!-- Logo -->
      <a href="/" style="display:flex;align-items:center;gap:8px;text-decoration:none;flex-shrink:0;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#D4A843,#A87420);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="9" stroke="white" stroke-width="1.8"/>
            <path d="M12 7v1m0 8v1M9.5 9.5C9.5 8.67 10.67 8 12 8s2.5.67 2.5 1.5S13.33 11 12 11s-2.5.67-2.5 1.5S10.67 14 12 14s2.5.67 2.5 1.5" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </div>
        <span style="font-family:'Plus Jakarta Sans',sans-serif;font-size:18px;font-weight:700;color:white;white-space:nowrap;line-height:1;">
          Simulador<span style="color:#FDE047;">de</span>Créditos
        </span>
      </a>

      <!-- Links desktop -->
      <div class="desk-nav" style="display:none;align-items:center;gap:2px;">

        <!-- Calculadora -->
        <a href="/"
           style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;text-decoration:none;white-space:nowrap;color:${isActive('/')?'#D4A843':'rgba(255,255,255,.75)'};`}>
          Calculadora
        </a>

        <!-- Créditos dropdown -->
        <div class="nav-dropdown" style="position:relative;">
          <button class="nav-drop-btn" style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;background:none;border:none;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;color:${(isActive('/vivienda-social')||isActive('/requisitos'))?'#D4A843':'rgba(255,255,255,.75)'};`}>
            Créditos
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="nav-drop-menu" style="display:none;position:absolute;top:calc(100% + 8px);left:0;background:#fff;border-radius:14px;box-shadow:0 8px 32px rgba(10,31,66,.18);border:1px solid #E5EDF8;min-width:220px;padding:6px;z-index:100;">
            <a href="/vivienda-social" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;transition:background .15s;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">🏠</span>
              <div>
                <div>Crédito VIS</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Vivienda de Interés Social</div>
              </div>
            </a>
            <a href="/requisitos" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;transition:background .15s;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">📋</span>
              <div>
                <div>Requisitos</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Documentos para tu crédito</div>
              </div>
            </a>
            <a href="/creditos/microcredito" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">🏪</span>
              <div>
                <div>Microcrédito</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Guía para emprendedores</div>
              </div>
            </a>
          </div>
        </div>

        <!-- DPF dropdown -->
        <div class="nav-dropdown" style="position:relative;">
          <button class="nav-drop-btn" style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;background:none;border:none;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;color:${isActive('/dpf')?'#D4A843':'rgba(255,255,255,.75)'};`}>
            DPF
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="nav-drop-menu" style="display:none;position:absolute;top:calc(100% + 8px);left:0;background:#fff;border-radius:14px;box-shadow:0 8px 32px rgba(10,31,66,.18);border:1px solid #E5EDF8;min-width:220px;padding:6px;z-index:100;">
            <a href="/dpf/calculadora" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;transition:background .15s;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">💰</span>
              <div>
                <div>Calculadora DPF</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Interés neto con RC-IVA</div>
              </div>
            </a>
            <a href="/dpf/tasas-en-bolivia" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;transition:background .15s;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">📊</span>
              <div>
                <div>Tasas en Bolivia</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Comparativa de bancos</div>
              </div>
            </a>
          </div>
        </div>

        <!-- Inversiones -->
        <a href="/inversiones"
           style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;text-decoration:none;white-space:nowrap;color:${isActive('/inversiones')?'#D4A843':'rgba(255,255,255,.75)'};`}>
          Inversiones
        </a>

        <!-- Ayuda dropdown -->
        <div class="nav-dropdown" style="position:relative;">
          <button class="nav-drop-btn" style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;background:none;border:none;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;color:${isActive('/ayuda')?'#D4A843':'rgba(255,255,255,.75)'};`}>
            Ayuda
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="nav-drop-menu" style="display:none;position:absolute;top:calc(100% + 8px);left:0;background:#fff;border-radius:14px;box-shadow:0 8px 32px rgba(10,31,66,.18);border:1px solid #E5EDF8;min-width:220px;padding:6px;z-index:100;">
            <a href="/ayuda/dudas-frecuentes" style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:#0A1F42;font-size:13px;font-weight:600;" onmouseover="this.style.background='#F0F4FB'" onmouseout="this.style.background='transparent'">
              <span style="font-size:16px;">❓</span>
              <div>
                <div>Dudas Frecuentes</div>
                <div style="font-size:11px;font-weight:400;color:#6B7A8D;">Preguntas sobre créditos y finanzas</div>
              </div>
            </a>
          </div>
        </div>

        <!-- TRE -->
        <a href="/tre"
           style={`font-size:13px;font-weight:600;padding:6px 11px;border-radius:8px;text-decoration:none;white-space:nowrap;color:${isActive('/tre')?'#D4A843':'rgba(255,255,255,.75)'};`}>
          TRE
        </a>

      </div>

      <!-- Derecha: TRE pill + hamburger -->
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">

        <!-- TRE solo desktop -->
        <div class="tre-desktop" style="display:none;align-items:center;gap:6px;background:rgba(212,168,67,.12);border:1px solid rgba(212,168,67,.35);border-radius:20px;padding:4px 11px;font-size:11px;color:#C9A840;font-weight:700;white-space:nowrap;">
          <div style="width:6px;height:6px;border-radius:50%;background:#D4A843;animation:trepulse 2s infinite;flex-shrink:0;"></div>
          TRE:&nbsp;<strong id="hdrTRE" class="tre-value">2.95</strong>%
        </div>

        <!-- Hamburger -->
        <button
          id="hamburger"
          aria-label="Abrir menú"
          style="background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.25);border-radius:8px;padding:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;"
          class="ham-btn"
        >
          <svg id="iconMenu" width="22" height="22" viewBox="0 0 24 24" fill="none">
            <line x1="3" y1="6"  x2="21" y2="6"  stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="3" y1="12" x2="21" y2="12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="3" y1="18" x2="21" y2="18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <svg id="iconClose" width="22" height="22" viewBox="0 0 24 24" fill="none" style="display:none;">
            <line x1="6" y1="6"  x2="18" y2="18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="18" y1="6" x2="6"  y2="18" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Menú mobile -->
  <div id="mobileMenu" style="display:none;background:rgba(6,15,30,.98);border-top:1px solid rgba(255,255,255,.08);">
    <div style="padding:12px 16px;display:flex;flex-direction:column;gap:2px;">

      <a href="/" style={`padding:11px 14px;border-radius:10px;font-size:15px;font-weight:600;text-decoration:none;display:block;color:${isActive('/')?'#D4A843':'rgba(255,255,255,.85)'};background:${isActive('/')?'rgba(212,168,67,.12)':'transparent'};`}>
        🧮 Calculadora de Créditos
      </a>

      <!-- Sección Créditos -->
      <div style="padding:8px 14px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.35);">Créditos</div>
      <a href="/vivienda-social" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/vivienda-social')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/vivienda-social')?'rgba(212,168,67,.12)':'transparent'};`}>
        🏠 Crédito VIS
      </a>
      <a href="/requisitos" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/requisitos')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/requisitos')?'rgba(212,168,67,.12)':'transparent'};`}>
        📋 Requisitos
      </a>
      <a href="/creditos/microcredito" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/creditos')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/creditos')?'rgba(212,168,67,.12)':'transparent'};`}>
        🏪 Microcrédito
      </a>

      <!-- Sección DPF -->
      <div style="padding:8px 14px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.35);margin-top:4px;">Depósito a Plazo Fijo</div>
      <a href="/dpf/calculadora" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/dpf/calculadora')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/dpf/calculadora')?'rgba(212,168,67,.12)':'transparent'};`}>
        💰 Calculadora DPF
      </a>
      <a href="/dpf/tasas-en-bolivia" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/dpf/tasas-en-bolivia')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/dpf/tasas-en-bolivia')?'rgba(212,168,67,.12)':'transparent'};`}>
        📊 Tasas en Bolivia
      </a>

      <!-- Inversiones -->
      <a href="/inversiones" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/inversiones')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/inversiones')?'rgba(212,168,67,.12)':'transparent'};`}>
        📈 Inversiones en Bolivia
      </a>

      <!-- Sección Ayuda -->
      <div style="padding:8px 14px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.35);margin-top:4px;">Ayuda</div>
      <a href="/ayuda/dudas-frecuentes" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/ayuda')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/ayuda')?'rgba(212,168,67,.12)':'transparent'};`}>
        ❓ Dudas Frecuentes
      </a>

      <!-- TRE -->
      <div style="margin-top:4px;">
        <a href="/tre" style={`padding:11px 14px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;display:block;color:${isActive('/tre')?'#D4A843':'rgba(255,255,255,.80)'};background:${isActive('/tre')?'rgba(212,168,67,.12)':'transparent'};`}>
          📈 ¿Qué es la TRE?
        </a>
      </div>

      <!-- TRE pill mobile -->
      <div style="margin-top:10px;padding:10px 14px;border-radius:10px;background:rgba(212,168,67,.10);border:1px solid rgba(212,168,67,.25);display:flex;align-items:center;gap:8px;">
        <div style="width:7px;height:7px;border-radius:50%;background:#D4A843;flex-shrink:0;"></div>
        <span style="font-size:13px;color:#D4A843;font-weight:700;">TRE Vigente: <span class="tre-value">2.95</span>%</span>
      </div>

    </div>
  </div>

</nav>

<style is:global>
  @keyframes trepulse { 0%,100%{opacity:1} 50%{opacity:.35} }

  @media (min-width: 768px) {
    .desk-nav  { display:flex !important; }
    .tre-desktop { display:flex !important; }
    .ham-btn   { display:none !important; }
  }

  /* Dropdown hover */
  /* El hover ahora lo maneja JS para evitar el gap entre botón y menú */
  .nav-drop-btn:hover { color:#D4A843 !important; }

  /* Animación dropdown */
  .nav-drop-menu {
    animation: dropFade .15s ease forwards;
  }
  @keyframes dropFade {
    from { opacity:0; transform:translateY(-6px); }
    to   { opacity:1; transform:translateY(0); }
  }
</style>

<script is:inline>
  (function () {
    var hamburger  = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobileMenu');
    var iconMenu   = document.getElementById('iconMenu');
    var iconClose  = document.getElementById('iconClose');
    if (!hamburger || !mobileMenu) return;

    function open() {
      mobileMenu.style.display = 'block';
      iconMenu.style.display   = 'none';
      iconClose.style.display  = 'block';
      hamburger.setAttribute('aria-expanded', 'true');
    }
    function close() {
      mobileMenu.style.display = 'none';
      iconMenu.style.display   = 'block';
      iconClose.style.display  = 'none';
      hamburger.setAttribute('aria-expanded', 'false');
    }

    hamburger.addEventListener('click', function(e) {
      e.stopPropagation();
      mobileMenu.style.display === 'none' ? open() : close();
    });
    document.addEventListener('click', function(e) {
      if (mobileMenu.style.display !== 'none' &&
          !mobileMenu.contains(e.target) &&
          !hamburger.contains(e.target)) close();
    });
    window.addEventListener('resize', function() {
      if (window.innerWidth >= 768) close();
    });
    /* ── Dropdowns con delay para evitar cierre al cruzar el gap ── */
    document.querySelectorAll('.nav-dropdown').forEach(function(dropdown) {
      var menu  = dropdown.querySelector('.nav-drop-menu');
      var timer = null;

      function showMenu() {
        clearTimeout(timer);
        menu.style.display = 'block';
      }
      function hideMenu() {
        timer = setTimeout(function() {
          menu.style.display = 'none';
        }, 120);
      }

      dropdown.addEventListener('mouseenter', showMenu);
      dropdown.addEventListener('mouseleave', hideMenu);
      menu.addEventListener('mouseenter', showMenu);
      menu.addEventListener('mouseleave', hideMenu);
    });

  })();
</script>
