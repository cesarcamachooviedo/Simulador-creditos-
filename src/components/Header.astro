---
/**
 * Header.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Navegación unificada y sticky para todas las páginas del sitio.
 */

const pathname = Astro.url.pathname;

// Helper optimizado para producción en Cloudflare (limpia barras finales antes de comparar)
const cleanPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;

const isActive = (href: string): boolean => {
  if (href === '/') return cleanPath === '/' || cleanPath === '/index';
  return cleanPath === href || cleanPath.startsWith(href + '/');
};
---

<nav
  class="hero-bg sticky top-0 z-50"
  style="box-shadow: 0 2px 20px rgba(0,0,0,.35);"
  aria-label="Navegación principal"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <a href="/" class="flex items-center gap-2.5 flex-shrink-0" aria-label="SimuladordeCreditos.com - Inicio">
        <div class="w-9 h-9 rounded-xl gold-bg flex items-center justify-center shadow-lg border border-yellow-500/30">
          <svg class="w-5 h-5 text-slate-900 stroke-[2.5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.251.11a3.375 3.375 0 004.496-2.355c.192-.952-.247-1.923-1.124-2.365L11.75 9.64c-.877-.441-1.316-1.413-1.124-2.365a3.375 3.375 0 014.496-2.355c.25.11.25.11.25.11M12 3v18" />
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="font-display font-black tracking-tight text-white text-base leading-none">Simulador<span class="text-yellow-400 font-medium">de</span>Créditos</span>
          <span class="text-[9px] font-mono-num tracking-[.25em] text-blue-300/80 uppercase mt-0.5 font-bold">Bolivia</span>
        </div>
      </a>

      <div class="hidden md:flex items-center gap-1">
        <a 
          href="/" 
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-150 ${isActive('/') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
        >
          Calculadora
        </a>
        <a 
          href="/tre" 
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-150 ${isActive('/tre') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
        >
          ¿Qué es la TRE?
        </a>
        <a 
          href="/requisitos" 
          class={`px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all duration-150 ${isActive('/requisitos') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
        >
          Requisitos
        </a>
      </div>

      <div class="hidden sm:flex items-center gap-3 bg-slate-950/40 border border-white/5 rounded-2xl py-1.5 pl-3.5 pr-4 shadow-inner">
        <div class="flex flex-col items-end">
          <span class="text-[9px] font-bold uppercase tracking-widest text-blue-300/70 leading-none">TRE Vigente</span>
          <span class="text-[10px] text-slate-400 mt-0.5 leading-none">Mayo 2026</span>
        </div>
        <div class="h-6 w-px bg-white/10"></div>
        <strong id="hdrTRE" class="font-mono-num text-base font-bold text-yellow-400 leading-none">-- %</strong>
      </div>

      <div class="flex items-center md:hidden">
        <button
          id="hamburgerBtn"
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-xl text-blue-200 hover:text-white hover:bg-white/5 focus:outline-none transition-colors duration-150"
          aria-controls="mobileMenu"
          aria-expanded="false"
        >
          <span class="sr-only">Abrir menú principal</span>
          <svg id="iconMenu" class="block h-6 w-6 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="iconClose" class="hidden h-6 w-6 stroke-[2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <div class="hidden md:hidden bg-[#071328] border-t border-white/5" id="mobileMenu">
    <div class="px-2 pt-2 pb-4 space-y-1 shadow-2xl">
      <a
        href="/"
        class={`block px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${isActive('/') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
      >
        Calculadora de Crédito
      </a>
      <a
        href="/tre"
        class={`block px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${isActive('/tre') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
      >
        ¿Qué es la TRE?
      </a>
      <a
        href="/requisitos"
        class={`block px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${isActive('/requisitos') ? 'text-yellow-400 bg-white/5' : 'text-blue-100 hover:text-white hover:bg-white/5'}`}
      >
        Requisitos de Admisión
      </a>
    </div>
  </div>
</nav>

<script>
  // Manejo interactivo del menú móvil en el cliente
  const hamburger = document.getElementById('hamburgerBtn');
  const mobileMenu = document.getElementById('mobileMenu');
  const iconMenu = document.getElementById('iconMenu');
  const iconClose = document.getElementById('iconClose');

  if (hamburger && mobileMenu && iconMenu && iconClose) {
    function toggleMenu() {
      const isOpen = !mobileMenu.classList.contains('hidden');

      if (isOpen) {
        mobileMenu.classList.add('hidden');
        hamburger.setAttribute('aria-expanded', 'false');
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
      } else {
        mobileMenu.classList.remove('hidden');
        hamburger.setAttribute('aria-expanded', 'true');
        iconMenu.classList.add('hidden');
        iconClose.classList.remove('hidden');
      }
    }

    hamburger.addEventListener('click', toggleMenu);

    // Cerrar al hacer clic fuera del menú
    document.addEventListener('click', function (e) {
      const target = e.target as HTMLElement;
      if (
        !mobileMenu.classList.contains('hidden') &&
        !mobileMenu.contains(target) &&
        !hamburger.contains(target)
      ) {
        mobileMenu.classList.add('hidden');
        hamburger.setAttribute('aria-expanded', 'false');
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }
    });

    // Cerrar al redimensionar a escritorio
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 768) {
        mobileMenu.classList.add('hidden');
        hamburger.setAttribute('aria-expanded', 'false');
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }
    });
  }
</script>
