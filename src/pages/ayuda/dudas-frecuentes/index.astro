---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Preguntas Frecuentes sobre Créditos en Bolivia 2026"
  description="Respuestas claras a las dudas más comunes sobre créditos, DPF y el sistema financiero boliviano. Central de Riesgos, pago anticipado, Sistema Francés vs Alemán y más."
>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo sé si estoy en la Central de Riesgos (CENCREF) en Bolivia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Podés consultar tu historial crediticio directamente en el sitio web de la ASFI (asfi.gob.bo) con tu Cédula de Identidad. El sistema muestra tu calificación actual: A (sin mora), B (1-30 días), C (31-60 días), D (61-90 días) o E (más de 90 días). Las calificaciones D y E impiden acceder a nuevos créditos en el sistema financiero regulado."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo pagar mi crédito antes de tiempo en Bolivia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. La Ley 393 de Servicios Financieros garantiza el derecho al pago anticipado sin penalidades ni comisiones. Podés realizar amortizaciones extraordinarias al capital en cualquier momento."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es mejor, el Sistema Francés o el Sistema Alemán?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El Sistema Francés tiene cuotas fijas iguales durante todo el plazo. El Sistema Alemán tiene cuotas decrecientes y genera menos intereses totales. Si tenés ingresos estables, el Francés es más predecible. Si podés pagar más al inicio y querés ahorrar en intereses totales, el Alemán conviene más."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si me atraso en el pago de una cuota?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desde el primer día de mora el banco puede cobrar intereses penales. A partir de 1 día tu calificación puede cambiar a B. Con más de 60 días pasás a C o D. Si sabés que no podés pagar, contactá al banco antes del vencimiento para explorar opciones de refinanciamiento."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es el Fondo de Protección al Ahorrista (FOPA) en Bolivia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El FOPA cubre hasta UFV 250,000 por persona por entidad financiera regulada por la ASFI. Si un banco o cooperativa quiebra, el Estado garantiza esa suma."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto crédito me pueden dar según mi sueldo en Bolivia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El estándar ASFI establece que la cuota mensual no debe superar el 25% del ingreso neto para bajo riesgo. El límite máximo aceptado es el 30%. Con un sueldo de Bs. 8,000, la cuota máxima es entre Bs. 2,000 y Bs. 2,400."
      }
    }
  ]
}
</script>

<style is:global>
  .hero-bg { background:linear-gradient(135deg,#060F1E 0%,#0A1F42 45%,#0D2860 100%); }
  .gold-bg  { background:linear-gradient(135deg,#D4A843 0%,#A87420 100%); }
  .card     { background:#fff; border-radius:16px; box-shadow:0 2px 18px rgba(10,31,66,.08); }
  .font-mono-num { font-family:'DM Mono','Courier New',monospace; font-weight:500; }
  .badge-gold  { background:rgba(212,168,67,.14);border:1px solid rgba(212,168,67,.40);color:#A87420;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.04em;display:inline-block; }
  .badge-green { background:#D1FAE5;color:#065F46;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .badge-blue  { background:#DBEAFE;color:#1E40AF;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .cat-tabs { display:flex;gap:4px;background:#F0F4FB;padding:5px;border-radius:14px;overflow-x:auto;flex-wrap:wrap; }
  .cat-tab  { padding:9px 16px;border-radius:10px;border:none;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:13px;font-weight:600;color:#4B6A9B;background:transparent;transition:all .2s;white-space:nowrap; }
  .cat-tab.active { background:#0A1F42;color:#fff;box-shadow:0 2px 10px rgba(10,31,66,.25); }
  .faq-item { border-radius:14px;border:1.5px solid #E8EEF8;margin-bottom:8px;overflow:hidden;transition:border-color .2s; }
  .faq-item:hover { border-color:#CBD5E1; }
  .faq-item.open  { border-color:#0A1F42; }
  .faq-btn { width:100%;display:flex;align-items:flex-start;justify-content:space-between;padding:18px 20px;background:none;border:none;cursor:pointer;text-align:left;font-family:'Plus Jakarta Sans',sans-serif;font-size:15px;font-weight:600;color:#0A1F42;gap:12px;line-height:1.4; }
  .faq-chevron { width:24px;height:24px;border-radius:8px;background:#F0F4FB;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .25s,background .2s;margin-top:1px; }
  .faq-item.open .faq-chevron { transform:rotate(180deg);background:#0A1F42; }
  .faq-item.open .faq-chevron svg { stroke:white; }
  .faq-body { max-height:0;overflow:hidden;transition:max-height .38s cubic-bezier(.4,0,.2,1); }
  .faq-item.open .faq-body { max-height:800px; }
  .faq-body-inner { padding:0 20px 20px; }
  .credit-row { display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #EDF2F9; }
  .credit-row:last-child { border-bottom:none; }
  .credit-badge { width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;flex-shrink:0; }
  .comp-tbl { width:100%;border-collapse:separate;border-spacing:0;font-size:13px; }
  .comp-tbl th { padding:10px 14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em; }
  .comp-tbl th:first-child { text-align:left; }
  .comp-tbl td { padding:10px 14px;border-bottom:1px solid #EDF2F9;font-size:13px; }
  .comp-tbl td:first-child { font-weight:600;color:#4B6A9B; }
  .comp-tbl tbody tr:last-child td { border-bottom:none; }
  .search-box { width:100%;padding:13px 16px 13px 44px;border:1.5px solid #D1DCF0;border-radius:12px;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;color:#0A1F42;background:#F7FAFF;outline:none;transition:border-color .2s,box-shadow .2s; }
  .search-box:focus { border-color:#D4A843;background:#fff;box-shadow:0 0 0 3px rgba(212,168,67,.15); }
</style>

<section class="hero-bg text-white relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div style="position:absolute;top:-60px;right:-80px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,.09) 0%,transparent 70%)"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 relative">
    <div class="max-w-3xl">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="badge-gold uppercase">Centro de Ayuda</span>
        <span class="badge-green">Normativa ASFI 2026</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight mb-4">
        Dudas Frecuentes sobre<br><span class="text-yellow-300">Créditos y Finanzas</span><br>en Bolivia
      </h1>
      <p class="text-blue-200 text-base sm:text-lg leading-relaxed max-w-2xl">
        Respuestas claras y directas a las preguntas que más nos hacen. Sin tecnicismos innecesarios, con la normativa boliviana como referencia.
      </p>
    </div>
  </div>
</section>

<div class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div class="text-center"><p class="font-mono-num text-xl font-bold text-navy-900">25%</p><p class="text-slate-500 text-xs mt-0.5">Límite cuota/ingreso óptimo</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-xl font-bold text-green-600">0%</p><p class="text-slate-500 text-xs mt-0.5">Penalidad por pago anticipado</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-xl font-bold text-yellow-600">UFV 250k</p><p class="text-slate-500 text-xs mt-0.5">Cobertura FOPA por entidad</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-xl font-bold text-navy-900">5</p><p class="text-slate-500 text-xs mt-0.5">Calificaciones crediticias</p></div>
  </div>
</div>

<section class="py-12 sm:py-16 max-w-4xl mx-auto px-4 sm:px-6">
  <div class="relative mb-8">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4B6A9B" stroke-width="2" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);">
      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
    </svg>
    <input type="text" id="faqSearch" class="search-box" placeholder="Buscá una pregunta... ej: Central de Riesgos, pago anticipado" oninput="filterFAQs(this.value)">
  </div>
  <div class="cat-tabs mb-8">
    <button class="cat-tab active" data-cat="todos"    onclick="filterCat('todos',this)">Todas</button>
    <button class="cat-tab"        data-cat="creditos" onclick="filterCat('creditos',this)">Créditos</button>
    <button class="cat-tab"        data-cat="riesgos"  onclick="filterCat('riesgos',this)">Central de Riesgos</button>
    <button class="cat-tab"        data-cat="dpf"      onclick="filterCat('dpf',this)">DPF e Inversión</button>
    <button class="cat-tab"        data-cat="legal"    onclick="filterCat('legal',this)">Derechos</button>
  </div>
  <p class="text-sm text-slate-400 mb-4" id="faqCount"></p>
  <div id="faqContainer"></div>
  <div id="noResults" class="hidden text-center py-12">
    <div class="text-4xl mb-3">🔍</div>
    <h3 class="font-display text-xl font-semibold text-slate-400">No encontramos esa pregunta</h3>
    <p class="text-slate-400 text-sm mt-1">Probá con otras palabras o explorá todas las categorías.</p>
  </div>
</section>

<section class="py-12 sm:py-16" style="background:linear-gradient(135deg,#F0F4FF,#EEF2FA)">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <span class="badge-gold uppercase">Guía Visual</span>
      <h2 class="font-display text-3xl font-semibold mt-3">Calificaciones de la Central de Riesgos</h2>
      <p class="text-slate-500 mt-2">Qué significa cada letra y cómo afecta tu acceso al crédito</p>
    </div>
    <div class="card p-6">
      <div class="space-y-0">
        <div class="credit-row">
          <div class="credit-badge" style="background:#D1FAE5;color:#065F46;">A</div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="font-bold text-sm text-navy-900">Sin mora — Al día</p>
              <span class="badge-green">Acceso pleno</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">0 días de atraso. Podés acceder a cualquier crédito del sistema financiero.</p>
          </div>
        </div>
        <div class="credit-row">
          <div class="credit-badge" style="background:#DBEAFE;color:#1E40AF;">B</div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="font-bold text-sm text-navy-900">Mora leve — 1 a 30 días</p>
              <span class="badge-blue">Acceso condicionado</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">Pequeño retraso. La mayoría de bancos aún aprueban créditos con análisis adicional.</p>
          </div>
        </div>
        <div class="credit-row">
          <div class="credit-badge" style="background:#FEF3C7;color:#92400E;">C</div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="font-bold text-sm text-navy-900">Mora moderada — 31 a 60 días</p>
              <span style="background:#FEF3C7;color:#92400E;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;">Difícil acceso</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">Riesgo elevado. Muy pocos bancos aprueban. Se recomienda regularizar inmediatamente.</p>
          </div>
        </div>
        <div class="credit-row">
          <div class="credit-badge" style="background:#FEE2E2;color:#991B1B;">D</div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="font-bold text-sm text-navy-900">Mora grave — 61 a 90 días</p>
              <span style="background:#FEE2E2;color:#991B1B;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;">Sin acceso</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">Acceso bloqueado al crédito. El banco puede iniciar proceso de cobro legal.</p>
          </div>
        </div>
        <div class="credit-row">
          <div class="credit-badge" style="background:#1A1A2E;color:#F87171;">E</div>
          <div class="flex-1">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="font-bold text-sm text-navy-900">Mora crítica — Más de 90 días</p>
              <span style="background:#7F1D1D;color:#FCA5A5;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;">Bloqueado</span>
            </div>
            <p class="text-xs text-slate-500 mt-0.5">Situación crítica. El banco puede ejecutar garantías. Requiere acuerdo de pago formal.</p>
          </div>
        </div>
      </div>
      <div class="mt-5 p-4 rounded-2xl" style="background:#EFF6FF;border:1px solid #BFDBFE;">
        <p class="text-sm text-blue-700 font-semibold mb-1">¿Cómo limpiar tu historial?</p>
        <p class="text-xs text-blue-600 leading-relaxed">Una vez que regularizás la deuda, la calificación vuelve a A automáticamente. Sin embargo, el historial de mora queda registrado. Cuanto antes regularicés, menor será el impacto a largo plazo.</p>
      </div>
    </div>
  </div>
</section>

<section class="py-12 sm:py-16 max-w-5xl mx-auto px-4 sm:px-6">
  <div class="text-center mb-10">
    <span class="badge-gold uppercase">Comparativa</span>
    <h2 class="font-display text-3xl font-semibold mt-3">Sistema Francés vs Sistema Alemán</h2>
    <p class="text-slate-500 mt-2">La diferencia que puede costarte miles de bolivianos si no la entendés antes de firmar</p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="card p-6" style="border-top:4px solid #0A1F42;">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#EEF4FF;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-base text-navy-900">Sistema Francés</h3>
          <p class="text-xs text-blue-500">Cuotas iguales · El más común en Bolivia</p>
        </div>
      </div>
      <div class="flex items-end gap-1 mb-4" style="height:60px;">
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
        <div style="flex:1;height:100%;background:#0A1F42;border-radius:3px 3px 0 0;opacity:.8;"></div>
      </div>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between py-1.5 border-b border-gray-100"><span class="text-slate-500">Cuotas</span><strong>Siempre iguales</strong></div>
        <div class="flex justify-between py-1.5 border-b border-gray-100"><span class="text-slate-500">Cuota inicial</span><strong class="text-green-600">Menor</strong></div>
        <div class="flex justify-between py-1.5"><span class="text-slate-500">Intereses totales</span><strong class="text-red-500">Más altos</strong></div>
      </div>
      <div class="mt-4 p-3 rounded-xl text-xs" style="background:#EEF4FF;color:#1E40AF;">Ideal para ingresos fijos y estables. Fácil de presupuestar.</div>
    </div>
    <div class="card p-6" style="border-top:4px solid #D4A843;">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#FEF3C7;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-base text-navy-900">Sistema Alemán</h3>
          <p class="text-xs text-yellow-600">Cuotas decrecientes · Menos común</p>
        </div>
      </div>
      <div class="flex items-end gap-1 mb-4" style="height:60px;">
        <div style="flex:1;height:100%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:91.6%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:83.3%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:75%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:66.6%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:58.3%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:50%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:41.6%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:33.3%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:25%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:16.6%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
        <div style="flex:1;height:8.3%;background:linear-gradient(to top,#D4A843,#A87420);border-radius:3px 3px 0 0;"></div>
      </div>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between py-1.5 border-b border-gray-100"><span class="text-slate-500">Cuotas</span><strong>Decrecientes</strong></div>
        <div class="flex justify-between py-1.5 border-b border-gray-100"><span class="text-slate-500">Cuota inicial</span><strong class="text-red-500">Mayor</strong></div>
        <div class="flex justify-between py-1.5"><span class="text-slate-500">Intereses totales</span><strong class="text-green-600">Más bajos</strong></div>
      </div>
      <div class="mt-4 p-3 rounded-xl text-xs" style="background:#FFFBEB;color:#92400E;">Ideal si podés pagar más al inicio y querés ahorrar en intereses totales.</div>
    </div>
  </div>
  <div class="card p-6" style="border:1.5px solid #E5EDF8;">
    <h3 class="font-display text-xl font-semibold mb-4">Ejemplo con Bs. 100,000 a 5 años al 7%</h3>
    <div class="overflow-x-auto">
      <table class="comp-tbl">
        <thead>
          <tr style="background:#F8FAFF;">
            <th style="color:#4B6A9B;border-bottom:2px solid #E5EDF8;text-align:left;"></th>
            <th style="color:#0A1F42;border-bottom:2px solid #E5EDF8;text-align:center;">Sistema Francés</th>
            <th style="color:#A87420;border-bottom:2px solid #E5EDF8;text-align:center;">Sistema Alemán</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Cuota mes 1</td><td class="text-center font-mono-num">Bs. 1,980</td><td class="text-center font-mono-num">Bs. 2,250</td></tr>
          <tr><td>Cuota mes 60</td><td class="text-center font-mono-num">Bs. 1,980</td><td class="text-center font-mono-num" style="color:#16A34A;">Bs. 1,679</td></tr>
          <tr><td>Total intereses pagados</td><td class="text-center font-mono-num" style="color:#DC2626;">Bs. 18,801</td><td class="text-center font-mono-num" style="color:#16A34A;">Bs. 17,500</td></tr>
          <tr><td>Ahorro Sistema Alemán</td><td class="text-center text-slate-400">—</td><td class="text-center font-mono-num font-bold" style="color:#16A34A;">Bs. 1,301</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-slate-400 mt-3 italic">* Valores aproximados para ilustración.</p>
    <div class="mt-5 p-4 rounded-2xl flex gap-3 items-start" style="background:#EFF6FF;border:1px solid #BFDBFE;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1D4ED8" stroke-width="2" style="flex-shrink:0;margin-top:2px;"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
      <div>
        <p class="text-sm font-bold text-blue-800 mb-1">¿Cuál usa la banca boliviana en la práctica?</p>
        <p class="text-sm text-blue-700 leading-relaxed">La <strong>gran mayoría de bancos en Bolivia aplican exclusivamente el Sistema Francés</strong> para créditos de consumo, hipotecarios y vehiculares. Es el estándar del sistema financiero nacional regulado por la ASFI. El Sistema Alemán existe como alternativa teórica pero es muy poco frecuente en la oferta bancaria local — si querés utilizarlo, debés solicitarlo explícitamente y no todos los bancos lo ofrecen.</p>
      </div>
    </div>
  </div>
</section>

<section class="hero-bg py-14 text-center text-white">
  <div class="max-w-2xl mx-auto px-4">
    <div class="w-14 h-14 rounded-2xl gold-bg mx-auto mb-5 flex items-center justify-center">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
    </div>
    <h2 class="font-display text-3xl sm:text-4xl font-bold mb-3">¿Listo para simular tu crédito?</h2>
    <p class="text-blue-200 mb-7">Ahora que conocés las reglas del juego, usá nuestra calculadora para ver exactamente cuánto pagarás.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/" style="background:linear-gradient(135deg,#D4A843,#A87420);color:#fff;font-weight:700;padding:14px 30px;border-radius:12px;text-decoration:none;font-size:15px;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(212,168,67,.40);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
        Calculadora de Créditos
      </a>
      <a href="/dpf/calculadora" style="background:transparent;color:white;font-weight:700;padding:14px 30px;border-radius:12px;text-decoration:none;font-size:15px;display:inline-flex;align-items:center;gap:8px;border:2px solid rgba(255,255,255,.3);">
        Calculadora DPF
      </a>
    </div>
  </div>
</section>

<script is:inline>
"use strict";
var FAQS = [
  { cat:'creditos', q:'¿Cuánto crédito me pueden dar según mi sueldo?', a:'<p style="margin-bottom:12px;font-size:13px;">El estándar de la ASFI establece dos límites para la cuota mensual:</p><div style="margin-bottom:12px;font-size:13px;"><div style="display:flex;justify-content:space-between;margin-bottom:4px;"><span style="font-weight:600;">Límite óptimo (bajo riesgo)</span><span style="font-family:DM Mono,monospace;color:#16A34A;font-weight:700;">25% del ingreso neto</span></div><div style="height:8px;border-radius:4px;background:#E5EDF8;overflow:hidden;margin-bottom:8px;"><div style="height:100%;width:25%;background:#22C55E;border-radius:4px;"></div></div><div style="display:flex;justify-content:space-between;margin-bottom:4px;"><span style="font-weight:600;">Límite máximo aceptado</span><span style="font-family:DM Mono,monospace;color:#F59E0B;font-weight:700;">30% del ingreso neto</span></div><div style="height:8px;border-radius:4px;background:#E5EDF8;overflow:hidden;"><div style="height:100%;width:30%;background:#F59E0B;border-radius:4px;"></div></div></div><div style="background:#F8FAFF;border-radius:12px;padding:14px;font-size:13px;"><strong>Ejemplo con sueldo de Bs. 8,000:</strong><br>Cuota óptima: hasta <strong style="color:#16A34A;">Bs. 2,000</strong> · Cuota máxima: hasta <strong style="color:#F59E0B;">Bs. 2,400</strong></div><p style="margin-top:12px;font-size:13px;color:#4B6A9B;">Usá nuestra <a href="/" style="color:#D4A843;font-weight:700;">calculadora de capacidad de pago</a> para tu caso específico.</p>' },
  { cat:'creditos', q:'¿Qué es el Sistema Francés y cómo funciona?', a:'<p style="font-size:13px;color:#4B6A9B;margin-bottom:10px;">Es el sistema de amortización más usado en Bolivia. La cuota mensual es siempre la misma durante todo el plazo.</p><div style="background:#EEF4FF;border-radius:12px;padding:14px;font-family:DM Mono,monospace;font-size:14px;text-align:center;margin-bottom:12px;">Cuota = Capital × r / (1 − (1+r)^−n)</div><p style="font-size:13px;color:#4B6A9B;">Al inicio la mayor parte de la cuota es interés. Con el tiempo, la proporción de capital aumenta. Por eso conviene pagar anticipado en los primeros años.</p>' },
  { cat:'creditos', q:'¿En qué se diferencia el Crédito VIS del crédito hipotecario normal?', a:'<p style="font-size:13px;color:#4B6A9B;margin-bottom:12px;">El Crédito VIS tiene tasas máximas fijadas por ley:</p><div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;font-size:12px;"><div style="background:#EEF4FF;border-radius:10px;padding:12px;"><p style="font-weight:700;color:#0A1F42;margin-bottom:6px;">Crédito VIS</p><p>Tasa: 5.5% – 7.5% (fija por ley)</p><p>Plazo: hasta 30 años</p><p>Sin penalidad por prepago</p></div><div style="background:#F8FAFF;border-radius:10px;padding:12px;"><p style="font-weight:700;color:#0A1F42;margin-bottom:6px;">Hipotecario Normal</p><p>Tasa: 9% – 14% (variable)</p><p>Plazo: hasta 20-25 años</p><p>Puede tener comisiones</p></div></div><p style="margin-top:12px;font-size:13px;color:#4B6A9B;">Condición: debe ser tu primera y única vivienda, sin fines comerciales. <a href="/vivienda-social" style="color:#D4A843;font-weight:700;">Ver más sobre el crédito VIS →</a></p>' },
  { cat:'riesgos', q:'¿Cómo sé si estoy en la Central de Riesgos (CENCREF)?', a:'<p style="margin-bottom:12px;font-size:13px;color:#4B6A9B;">Podés consultarlo de forma gratuita:</p><div style="display:flex;gap:10px;flex-direction:column;font-size:13px;"><div style="display:flex;gap:10px;align-items:flex-start;padding:12px;background:#F0FDF4;border-radius:10px;"><span style="font-size:18px;flex-shrink:0;">🌐</span><div><strong>En línea:</strong> ingresá a <a href="https://asfi.gob.bo" target="_blank" style="color:#D4A843;font-weight:700;">asfi.gob.bo</a> con tu CI.</div></div><div style="display:flex;gap:10px;align-items:flex-start;padding:12px;background:#EEF4FF;border-radius:10px;"><span style="font-size:18px;flex-shrink:0;">🏢</span><div><strong>Presencial:</strong> en cualquier oficina de la ASFI.</div></div></div><p style="margin-top:12px;font-size:13px;color:#4B6A9B;background:#FEF3C7;padding:12px;border-radius:10px;">Consultá tu historial ANTES de ir al banco. Si tenés calificación C, D o E, regularizá primero.</p>' },
  { cat:'riesgos', q:'¿Cuánto tiempo tarda en limpiar mi historial crediticio?', a:'<p style="font-size:13px;color:#4B6A9B;margin-bottom:12px;">Una vez que pagás la deuda en mora, tu calificación vuelve a A automáticamente. Sin embargo:</p><ul style="font-size:13px;color:#4B6A9B;list-style:none;"><li style="padding:8px 0;border-bottom:1px solid #EDF2F9;">📌 El historial de mora queda registrado y es visible para los bancos aunque ya hayas pagado.</li><li style="padding:8px 0;border-bottom:1px solid #EDF2F9;">📌 Algunos bancos analizan el historial de los últimos 12-24 meses.</li><li style="padding:8px 0;">📌 Cuanto antes regularicés, más rápido mejorará tu perfil crediticio real.</li></ul>' },
  { cat:'legal', q:'¿Puedo pagar mi crédito antes de tiempo sin penalidades?', a:'<div style="background:#F0FDF4;border:1.5px solid #86EFAC;border-radius:12px;padding:16px;margin-bottom:14px;"><p style="font-weight:700;color:#16A34A;font-size:14px;margin-bottom:4px;">Sí, es tu derecho legal.</p><p style="font-size:13px;color:#166534;">La <strong>Ley 393 de Servicios Financieros</strong> garantiza el derecho a realizar amortizaciones anticipadas sin ninguna penalidad, comisión ni cargo adicional.</p></div><ul style="font-size:13px;color:#4B6A9B;list-style:none;"><li style="padding:6px 0;border-bottom:1px solid #EDF2F9;">→ Podés pagar una cuota extra indicando que es "amortización extraordinaria al capital".</li><li style="padding:6px 0;border-bottom:1px solid #EDF2F9;">→ El banco recalcula las cuotas siguientes o reduce el plazo.</li><li style="padding:6px 0;">→ Conviene especialmente en los primeros años del crédito.</li></ul>' },
  { cat:'legal', q:'¿Qué pasa si me atraso en el pago de una cuota?', a:'<div style="display:flex;flex-direction:column;gap:8px;font-size:13px;"><div style="display:flex;gap:10px;padding:10px 12px;background:#FFFBEB;border-radius:10px;border-left:3px solid #F59E0B;"><strong style="white-space:nowrap;color:#92400E;">Día 1</strong><span>Comienzan los intereses moratorios. Tu calificación puede pasar a B.</span></div><div style="display:flex;gap:10px;padding:10px 12px;background:#FEF2F2;border-radius:10px;border-left:3px solid #F87171;"><strong style="white-space:nowrap;color:#991B1B;">Día 31</strong><span>Calificación C. Acceso muy difícil a nuevos créditos.</span></div><div style="display:flex;gap:10px;padding:10px 12px;background:#FEE2E2;border-radius:10px;border-left:3px solid #EF4444;"><strong style="white-space:nowrap;color:#991B1B;">Día 61+</strong><span>Calificación D o E. Sin acceso a crédito. El banco puede iniciar proceso judicial.</span></div></div><p style="margin-top:12px;font-size:13px;color:#4B6A9B;background:#F0FDF4;padding:12px;border-radius:10px;">Si anticipás que no vas a poder pagar, contactá al banco ANTES del vencimiento para explorar refinanciamiento.</p>' },
  { cat:'dpf', q:'¿Qué es el RC-IVA y cuánto me descuentan del DPF?', a:'<p style="font-size:13px;color:#4B6A9B;margin-bottom:12px;">El <strong>RC-IVA</strong> es una retención del <strong style="color:#DC2626;">13%</strong> sobre los intereses de tu DPF.</p><div style="background:#0A1F42;border-radius:12px;padding:16px;text-align:center;margin-bottom:12px;color:white;"><p style="font-size:11px;color:#93C5FD;margin-bottom:8px;">Ejemplo: DPF Bs. 100,000 al 5% por 360 días</p><div style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;"><div><p style="font-size:11px;color:#93C5FD;">Interés bruto</p><p style="font-family:DM Mono,monospace;font-size:20px;color:#FDE047;">Bs. 5,000</p></div><div style="font-size:20px;color:#64748B;">−</div><div><p style="font-size:11px;color:#FCA5A5;">RC-IVA 13%</p><p style="font-family:DM Mono,monospace;font-size:20px;color:#F87171;">Bs. 650</p></div><div style="font-size:20px;color:#64748B;">=</div><div><p style="font-size:11px;color:#86EFAC;">Interés neto</p><p style="font-family:DM Mono,monospace;font-size:20px;color:#4ADE80;font-weight:700;">Bs. 4,350</p></div></div></div><p style="font-size:13px;color:#4B6A9B;"><strong>Exenciones:</strong> DPFs en BOB mayores a 3 años y empresas con NIT jurídico. <a href="/dpf/calculadora" style="color:#D4A843;font-weight:700;">Calculá tu interés neto →</a></p>' },
  { cat:'dpf', q:'¿Qué es el Fondo de Protección al Ahorrista (FOPA)?', a:'<div style="display:flex;gap:12px;align-items:flex-start;background:#F0FDF4;border-radius:12px;padding:16px;margin-bottom:12px;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" style="flex-shrink:0;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><div style="font-size:13px;"><p style="font-weight:700;color:#166534;margin-bottom:4px;">Cobertura: hasta UFV 250,000 por persona por entidad</p><p style="color:#166534;">Aproximadamente Bs. 596,000 al valor UFV actual.</p></div></div><p style="font-size:13px;color:#4B6A9B;margin-bottom:10px;">Si tenés más de UFV 250,000, distribuílos en varias entidades reguladas por la ASFI. Cada depósito queda cubierto por separado.</p><p style="font-size:13px;color:#4B6A9B;background:#FEF3C7;padding:12px;border-radius:10px;">Solo cubre entidades reguladas y supervisadas por la ASFI. Las casas de cambio y prestamistas informales no tienen esta protección.</p>' },
];

var currentCat = 'todos';
var currentSearch = '';

function renderFAQs() {
  var filtered = FAQS.filter(function(f) {
    var matchCat    = currentCat === 'todos' || f.cat === currentCat;
    var matchSearch = !currentSearch || f.q.toLowerCase().indexOf(currentSearch.toLowerCase()) !== -1;
    return matchCat && matchSearch;
  });
  var container = document.getElementById('faqContainer');
  var noResults = document.getElementById('noResults');
  var countEl   = document.getElementById('faqCount');
  if (!filtered.length) {
    container.innerHTML = '';
    noResults.classList.remove('hidden');
    countEl.textContent = '';
    return;
  }
  noResults.classList.add('hidden');
  countEl.textContent = filtered.length + ' pregunta' + (filtered.length !== 1 ? 's' : '');
  container.innerHTML = filtered.map(function(faq, i) {
    return '<div class="faq-item" id="faq-'+i+'">' +
      '<button class="faq-btn" onclick="toggleFAQ('+i+')">' +
        '<span style="flex:1;">'+faq.q+'</span>' +
        '<span class="faq-chevron"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0A1F42" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></span>' +
      '</button>' +
      '<div class="faq-body"><div class="faq-body-inner">'+faq.a+'</div></div>' +
    '</div>';
  }).join('');
}

function toggleFAQ(i) {
  var item   = document.getElementById('faq-'+i);
  var isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(function(el) { el.classList.remove('open'); });
  if (!isOpen) item.classList.add('open');
}

function filterCat(cat, btn) {
  currentCat = cat;
  document.querySelectorAll('.cat-tab').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  renderFAQs();
}

function filterFAQs(val) {
  currentSearch = val;
  renderFAQs();
}

document.addEventListener('DOMContentLoaded', function() { renderFAQs(); });
</script>

</BaseLayout>
