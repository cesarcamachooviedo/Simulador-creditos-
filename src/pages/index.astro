/* ══════════════════════════════════════════
   💰  LÓGICA FINANCIERA — SISTEMA FRANCÉS
   ══════════════════════════════════════════ */

/**
 * PMT — Cuota mensual de amortización francesa
 * PMT = PV × r / (1 − (1+r)^-n)
 *
 * @param {number} pv  Capital (saldo presente)
 * @param {number} r   Tasa mensual decimal  (ej: 0.00625 para 7.5% anual)
 * @param {number} n   Número de cuotas restantes
 * @returns {number}   Cuota capital + interés
 */
function pmt(pv, r, n) {
  if (n <= 0) return 0;
  if (r === 0) return pv / n;
  return pv * r / (1 - Math.pow(1 + r, -n));
}

/**
 * Genera la tabla de amortización completa
 * @param {object} p  Parámetros del crédito
 * @returns {Array}   Filas de la tabla
 */
function generarTabla(p) {
  const totalMeses = p.plazoAnios * 12;
  const tabla = [];
  let saldo = p.monto;

  /* ── Determinar tasas y fases ── */
  let r1, r2 = null, mesesF1;

  if (p.tipoTasa === 'fija') {
    r1      = p.tasaFija / 100 / 12;
    mesesF1 = totalMeses;
  } else if (p.tipoTasa === 'variable') {
    r1      = (p.treVar + p.spreadVar) / 100 / 12;
    mesesF1 = totalMeses;
  } else {                                   // mixta
    r1      = p.tasaMixtaFija / 100 / 12;
    r2      = (p.treMixta + p.spreadMixta) / 100 / 12;
    mesesF1 = Math.min(p.aniosFijos * 12, totalMeses - 1);
  }

  /* PMT Fase 1: calculado sobre el plazo TOTAL (francés puro) */
  const PMT1 = pmt(p.monto, r1, totalMeses);
  let PMT2   = null;

  let fecha = new Date(p.fechaInicio + 'T00:00:00');

  for (let i = 1; i <= totalMeses; i++) {
    /* Avanzar exactamente un mes */
    fecha = new Date(fecha.getFullYear(), fecha.getMonth() + 1, fecha.getDate());

    const fase2  = (p.tipoTasa === 'mixta') && (i > mesesF1);
    const rMes   = fase2 ? r2 : r1;

    /* Recalcular PMT al inicio de la Fase 2 */
    if (fase2 && i === mesesF1 + 1) {
      PMT2 = pmt(saldo, r2, totalMeses - mesesF1);
    }
    const cuotaCI = fase2 ? PMT2 : PMT1;

    /* Interés y capital del período */
    const interes = saldo * rMes;
    let   capital = cuotaCI - interes;

    /* Última cuota: liquidar saldo exacto */
    if (i === totalMeses || capital >= saldo) {
      capital = saldo;
    }

    /* ── Seguros (sobre saldo insoluto) ── */
    const segDesgrav = p.chkDesgrav ? saldo * (p.tasaDesgrav / 100) : 0;
    const segOtro    = p.chkSegOtro ? saldo * (p.tasaSegOtro  / 100) : 0;

    const cuotaTotal = capital + interes + segDesgrav + segOtro;

    saldo = Math.max(0, saldo - capital);

    tabla.push({
      nro: i,
      fecha: fmtFecha(fecha),
      capital, interes, segDesgrav, segOtro,
      cuotaCI: capital + interes,   // cuota pura capital+interés
      cuotaTotal, saldo,
      fase2
    });

    if (saldo === 0) break;
  }

  return tabla;
}

/* ══════════════════════════════════════════
   🔢  CALCULAR (main entry point)
   ══════════════════════════════════════════ */
function calcular() {
  /* ── Leer inputs ── */
  const tipoCredito = document.getElementById('tipoCredito').value;
  const moneda      = document.getElementById('moneda').value;
  const monto       = parseFloat(document.getElementById('monto').value);
  const plazoAnios  = parseInt(document.getElementById('plazo').value);
  const fechaInicio = document.getElementById('fechaInicio').value;

  if (!monto      || monto     <= 0) return alert('Ingrese un monto válido.');
  if (!plazoAnios || plazoAnios <= 0) return alert('Ingrese un plazo válido (1–30 años).');
  if (!fechaInicio)                   return alert('Seleccione la fecha del primer pago.');

  /* ── Tasas ── */
  let tasaFija=0, treVar=0, spreadVar=0;
  let tasaMixtaFija=0, aniosFijos=0, treMixta=0, spreadMixta=0;

  if (ST.tipoTasa === 'fija') {
    tasaFija = parseFloat(document.getElementById('tasaFija').value) || 0;
  } else if (ST.tipoTasa === 'variable') {
    treVar    = parseFloat(document.getElementById('treVar').value)    || DB_CONFIG.TRE;
    spreadVar = parseFloat(document.getElementById('spreadVar').value) || 0;
  } else {
    tasaMixtaFija = parseFloat(document.getElementById('tasaMixtaFija').value) || 0;
    aniosFijos    = parseInt(document.getElementById('aniosFijos').value)       || 0;
    treMixta      = parseFloat(document.getElementById('treMixta').value)       || DB_CONFIG.TRE;
    spreadMixta   = parseFloat(document.getElementById('spreadMixta').value)    || 0;

    if (aniosFijos <= 0 || aniosFijos >= plazoAnios)
      return alert(`El período fijo debe estar entre 1 y ${plazoAnios - 1} años.`);
  }

  /* ── Seguros ── */
  const chkDesgrav = document.getElementById('chkDesgrav').checked;
  const tasaDesgrav = parseFloat(document.getElementById('tasaDesgrav').value) || 0;
  const chkSegOtro  = document.getElementById('chkSegOtro').checked &&
                      !document.getElementById('segOtroWrap').classList.contains('hidden');
  const tasaSegOtro = parseFloat(document.getElementById('tasaSegOtro').value) || 0;

  const params = {
    monto, plazoAnios, tipoTasa: ST.tipoTasa,
    tasaFija, treVar, spreadVar,
    tasaMixtaFija, aniosFijos, treMixta, spreadMixta,
    chkDesgrav, tasaDesgrav,
    chkSegOtro,  tasaSegOtro,
    fechaInicio, tipoCredito, moneda,
  };

  ST.params  = params;
  ST.moneda  = moneda;
  ST.tabla   = generarTabla(params);
  ST.pagina  = 1;
  ST.verTodo = false;

  mostrarResultados();
}

/* ══════════════════════════════════════════
   📊  MOSTRAR RESULTADOS
   ══════════════════════════════════════════ */
function mostrarResultados() {
  const t    = ST.tabla;
  const p    = ST.params;
  if (!t.length) return;

  const r0  = t[0];  // primera fila
  const tot = (key) => t.reduce((s, r) => s + r[key], 0);

  const totalInt    = tot('interes');
  const totalDesgr  = tot('segDesgrav');
  const totalOtro   = tot('segOtro');
  const totalPagar  = p.monto + totalInt + totalDesgr + totalOtro;

  /* ── Summary cards ── */
  const f = (n) => fmtMoneda(n, ST.moneda);
  $('sC').textContent  = f(r0.cuotaCI);
  $('sCT').textContent = f(r0.cuotaTotal);
  $('sI').textContent  = f(totalInt);
  $('sIPct').textContent = ((totalInt / p.monto) * 100).toFixed(1) + '% del capital';
  $('sTP').textContent = f(totalPagar);

  /* ── Meta ── */
  const lblTasa = {
    fija:     `Tasa Fija ${p.tasaFija}%`,
    variable: `TRE (${p.treVar}%) + Spread (${p.spreadVar}%) = ${(p.treVar + p.spreadVar).toFixed(2)}%`,
    mixta:    `Mixta — Fija ${p.tasaMixtaFija}% (${p.aniosFijos}a) → Variable ${(p.treMixta+p.spreadMixta).toFixed(2)}%`,
  };
  $('tblMeta').textContent = `Sistema Francés · ${lblTasa[ST.tipoTasa]} · ${t.length} cuotas`;

  /* ── Gráfico composición ── */
  actualizarDonut(r0);

  /* ── Indicador de fases ── */
  $('faseInd').classList.toggle('hidden', ST.tipoTasa !== 'mixta');

  /* ── Capacidad de pago ── */
  const ingreso = parseFloat(document.getElementById('ingreso').value) || 0;
  if (ingreso > 0) mostrarCapacidad(r0.cuotaTotal, ingreso);
  else $('capSection').classList.add('hidden');

  /* ── Render tabla ── */
  renderTabla();

  /* ── Mostrar panel ── */
  $('placeholder').classList.add('hidden');
  $('resultados').classList.remove('hidden');

  /* Scroll en mobile */
  if (window.innerWidth < 1280) {
    setTimeout(() => $('resultados').scrollIntoView({ behavior:'smooth', block:'start' }), 80);
  }
}

/* ── Donut chart ── */
function actualizarDonut(r0) {
  const total = r0.cuotaTotal;
  const capPct  = total ? r0.capital    / total : 0;
  const intPct  = total ? r0.interes    / total : 0;
  const segPct  = total ? (r0.segDesgrav + r0.segOtro) / total : 0;

  /* circunferencia ≈ 327 (2π × 52) */
  const C = 2 * Math.PI * 52;
  const seg1 = capPct * C;
  const seg2 = intPct * C;
  const seg3 = segPct * C;

  /* Arco 1: capital (navy) */
  const a1 = $('dArc1');
  a1.setAttribute('stroke-dasharray', `${seg1} ${C - seg1}`);

  /* Arco 2: interés (gold) — offset tras arco 1 */
  const off2 = -seg1 * (C / (2 * Math.PI * 52));  // reuse ratio
  const a2 = $('dArc2');
  a2.setAttribute('stroke-dasharray', `${seg2} ${C - seg2}`);
  a2.setAttribute('stroke-dashoffset', -seg1 + 81.75);

  /* Arco 3: seguros (blue) */
  const a3 = $('dArc3');
  a3.setAttribute('stroke-dasharray', `${seg3} ${C - seg3}`);
  a3.setAttribute('stroke-dashoffset', -(seg1 + seg2) + 81.75);

  $('donutPct').textContent = (capPct * 100).toFixed(0) + '%';

  /* Leyenda + barras */
  const f = (n) => fmtMoneda(n, ST.moneda);
  $('lgCap').textContent    = f(r0.capital);
  $('lgCapPct').textContent = (capPct * 100).toFixed(1) + '%';
  $('barCap').style.width   = (capPct * 100) + '%';

  $('lgInt').textContent    = f(r0.interes);
  $('lgIntPct').textContent = (intPct * 100).toFixed(1) + '%';
  $('barInt').style.width   = (intPct * 100) + '%';

  const segTotal = r0.segDesgrav + r0.segOtro;
  $('lgSeg').textContent    = f(segTotal);
  $('lgSegPct').textContent = (segPct * 100).toFixed(1) + '%';
  $('barSeg').style.width   = (segPct * 100) + '%';
}

/* ── Capacidad de pago ── */
function mostrarCapacidad(cuota, ingreso) {
  const pct     = (cuota / ingreso) * 100;
  const section = $('capSection');
  section.classList.remove('hidden');

  let badgeCls, borderCls, bgCls, textCls, titulo, msg;

  if (pct <= DB_CONFIG.LIMITE_OPTIMO) {
    badgeCls  = 'badge-ok'; borderCls = 'border-green-500';
    bgCls     = 'bg-green-50'; textCls = 'text-green-800';
    titulo    = '✅ Capacidad Óptima';
    msg       = 'Tu cuota está dentro del límite óptimo del 25%. Los bancos consideran esta situación de <strong>bajo riesgo crediticio</strong>. Tienes excelentes probabilidades de aprobación.';
  } else if (pct <= DB_CONFIG.LIMITE_MAXIMO) {
    badgeCls  = 'badge-warn'; borderCls = 'border-yellow-500';
    bgCls     = 'bg-yellow-50'; textCls = 'text-yellow-800';
    titulo    = '⚠️ Capacidad Aceptable';
    msg       = 'Tu cuota supera el 25% pero está dentro del límite del 30%. Puede aprobarse con <strong>análisis adicional</strong>. Considera ampliar el plazo o reducir el monto.';
  } else {
    badgeCls  = 'badge-danger'; borderCls = 'border-red-500';
    bgCls     = 'bg-red-50'; textCls = 'text-red-800';
    titulo    = '❌ Riesgo Alto';
    msg       = 'Tu cuota supera el 30% de tus ingresos. La mayoría de entidades financieras <strong>rechazarían este crédito</strong>. Reduce el monto o extiende el plazo.';
  }

  const f  = (n) => fmtMoneda(n, ST.moneda);
  const bw = Math.min(pct, 100);
  const bc = pct <= 25 ? '#22C55E' : pct <= 30 ? '#F59E0B' : '#EF4444';
  const libre = Math.max(0, ingreso - cuota);

  $('capContent').innerHTML = `
    <div class="flex flex-col sm:flex-row sm:items-start gap-5">
      <div class="flex-1">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold text-navy-900">Cuota / Ingreso</span>
          <span class="px-3 py-1 rounded-full text-sm font-bold ${badgeCls}">${pct.toFixed(1)}%</span>
        </div>
        <div class="pbar mb-1">
          <div class="pbar-fill" style="width:${bw}%; background:${bc}"></div>
        </div>
        <div class="flex justify-between text-xs text-blue-400 mt-1">
          <span>0%</span>
          <span class="text-green-600 font-semibold">25% Óptimo</span>
          <span class="text-yellow-600 font-semibold">30% Límite</span>
          <span>50%+</span>
        </div>
      </div>
      <div class="flex flex-col items-center text-center sm:w-36">
        <p class="text-3xl mb-1">${pct <= 25 ? '🟢' : pct <= 30 ? '🟡' : '🔴'}</p>
        <p class="font-semibold text-sm text-navy-900 leading-tight">${titulo.replace(/[✅⚠️❌]\s*/,'')}</p>
      </div>
    </div>

    <div class="mt-4 bg-gray-50 rounded-xl p-4 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
      <div><p class="text-blue-400 text-xs">Ingreso Mensual</p><p class="font-semibold">${f(ingreso)}</p></div>
      <div><p class="text-blue-400 text-xs">Cuota Total</p><p class="font-semibold">${f(cuota)}</p></div>
      <div><p class="text-blue-400 text-xs">% del Ingreso</p>
           <p class="font-semibold ${pct>30?'text-red-600':pct>25?'text-yellow-600':'text-green-600'}">${pct.toFixed(2)}%</p></div>
      <div><p class="text-blue-400 text-xs">Límite 25% (Óptimo)</p><p class="font-semibold">${f(ingreso*0.25)}</p></div>
      <div><p class="text-blue-400 text-xs">Límite 30% (Máximo)</p><p class="font-semibold">${f(ingreso*0.30)}</p></div>
      <div><p class="text-blue-400 text-xs">Ingreso Disponible</p>
           <p class="font-semibold ${libre===0?'text-red-600':'text-green-600'}">${f(libre)}</p></div>
    </div>

    <div class="mt-3 p-3 rounded-xl border-l-4 ${borderCls} ${bgCls}">
      <p class="text-sm ${textCls}">${msg}</p>
    </div>`;
}

/* ══════════════════════════════════════════
   📋  RENDER TABLA
   ══════════════════════════════════════════ */
function renderTabla() {
  const t   = ST.tabla;
  const body = $('tblBody');
  const foot = $('tblFoot');

  let filas;
  if (ST.verTodo) {
    filas = t;
  } else {
    const ini = (ST.pagina - 1) * ST.porPagina;
    filas = t.slice(ini, ini + ST.porPagina);
  }

  body.innerHTML = filas.map(r => `
    <tr class="${r.fase2 ? 'fase2' : ''}">
      <td>
        <span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;
              border-radius:50%;font-size:11px;font-weight:600;
              background:${r.fase2 ? 'rgba(212,168,67,.18)' : '#EEF4FF'};
              color:${r.fase2 ? '#A87420' : '#0A1F42'}">${r.nro}</span>
      </td>
      <td>${r.fecha}</td>
      <td>${fmtNum(r.capital)}</td>
      <td>${fmtNum(r.interes)}</td>
      <td>${fmtNum(r.segDesgrav)}</td>
      <td>${fmtNum(r.segOtro)}</td>
      <td><strong>${fmtNum(r.cuotaTotal)}</strong></td>
      <td>${fmtNum(r.saldo)}</td>
    </tr>`).join('');

  /* Totales */
  const sm = (k) => t.reduce((s,r)=>s+r[k],0);
  foot.innerHTML = `<tr>
    <td colspan="2">TOTALES</td>
    <td>${fmtNum(sm('capital'))}</td>
    <td>${fmtNum(sm('interes'))}</td>
    <td>${fmtNum(sm('segDesgrav'))}</td>
    <td>${fmtNum(sm('segOtro'))}</td>
    <td><strong>${fmtNum(sm('cuotaTotal'))}</strong></td>
    <td>—</td>
  </tr>`;

  /* Paginación */
  const total = t.length;
  const ini   = (ST.pagina - 1) * ST.porPagina + 1;
  const fin   = Math.min(ST.pagina * ST.porPagina, total);

  if (ST.verTodo) {
    $('pgInfo').textContent = `Mostrando todas las ${total} cuotas`;
    $('btnPrev').style.display = 'none';
    $('btnNext').style.display = 'none';
  } else {
    $('pgInfo').textContent = `Cuotas ${ini}–${fin} de ${total}`;
    $('btnPrev').style.display = '';
    $('btnNext').style.display = '';
    $('btnPrev').disabled = ST.pagina === 1;
    $('btnNext').disabled = fin >= total;
  }
}

function cambiarPg(dir) {
  const max = Math.ceil(ST.tabla.length / ST.porPagina);
  ST.pagina = Math.max(1, Math.min(ST.pagina + dir, max));
  renderTabla();
  $('resultados').scrollIntoView({ behavior:'smooth', block:'start' });
}

function toggleAll() {
  ST.verTodo = !ST.verTodo;
  $('btnAll').textContent = ST.verTodo ? 'Paginar' : 'Ver todo';
  renderTabla();
}

/* ══════════════════════════════════════════
   📥  EXPORTAR CSV
   ══════════════════════════════════════════ */
function exportCSV() {
  if (!ST.tabla.length) return;
  const p = ST.params;

  const meta = [
    [`SimuladordeCreditos.com — Tabla de Amortización Sistema Francés`],
    [`Tipo:${p.tipoCredito}`,`Monto:${p.monto} ${ST.moneda}`,`Plazo:${p.plazoAnios} años`,
     `Tasa:${ST.tipoTasa}`,`Fecha:${new Date().toLocaleDateString('es-BO')}`],
    [],
  ];

  const hdr = ['Cuota','Fecha','Capital','Interes','Seg.Desgravamen','Seg.Otro',
                'Cuota Cap+Int','Cuota Total','Saldo','Fase'];

  const rows = ST.tabla.map(r => [
    r.nro, r.fecha,
    r.capital.toFixed(2), r.interes.toFixed(2),
    r.segDesgrav.toFixed(2), r.segOtro.toFixed(2),
    r.cuotaCI.toFixed(2), r.cuotaTotal.toFixed(2),
    r.saldo.toFixed(2), r.fase2 ? 2 : 1,
  ]);

  const csv = [
    ...meta.map(r => r.join(',')),
    hdr.join(','),
    ...rows.map(r => r.join(',')),
  ].join('\n');

  const blob = new Blob(['\uFEFF' + csv], { type:'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `amortizacion_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

/* ══════════════════════════════════════════
   🛠️  UTILIDADES
   ══════════════════════════════════════════ */
const $ = id => document.getElementById(id);

function fmtNum(n) {
  return n.toLocaleString('es-BO', { minimumFractionDigits:2, maximumFractionDigits:2 });
}

function fmtMoneda(n, moneda = 'BOB') {
  const s = { BOB:'Bs. ', USD:'US$ ', UFV:'UFV ' }[moneda] || 'Bs. ';
  if (n >= 1_000_000) return s + (n / 1_000_000).toFixed(3) + 'M';
  if (n >= 100_000)   return s + (n / 1_000).toFixed(1)     + 'k';
  return s + fmtNum(n);
}

function fmtCompact(n, moneda = 'BOB') {
  const s = { BOB:'Bs.', USD:'US$', UFV:'UFV' }[moneda] || 'Bs.';
  if (n >= 1_000_000) return `${s} ${(n/1_000_000).toFixed(2)}M`;
  if (n >= 1_000)     return `${s} ${(n/1_000).toFixed(0)}k`;
  return `${s} ${n}`;
}

function fmtFecha(date) {
  return date.toLocaleDateString('es-BO', { day:'2-digit', month:'2-digit', year:'numeric' });
}
</script>

</BaseLayout>
