---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Simulador de Créditos Bolivia 2026 — Calculá tu Cuota en Segundos"
  description="Simulá créditos hipotecarios, de vivienda social, microcréditos y más. Calculadora con Sistema Francés y Alemán, amortización completa y comparativa de cuotas. Bolivia 2026."
>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
<h1 class="sr-only">Simulador de Créditos Bolivia 2026</h1>
<div class="grid grid-cols-1 xl:grid-cols-5 gap-6 items-start">

  <div class="xl:col-span-2 space-y-5">

    <div class="card-bg p-6">
      <h2 class="font-display text-xl font-semibold mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0A1F42" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </span>
        Datos del Crédito
      </h2>
      <div class="space-y-4">

        <div>
          <label class="lbl">Tipo de Crédito</label>
          <select id="tipoCredito" class="inp" onchange="actualizarUI()">
            <option value="hipotecario">🏠  Crédito Hipotecario (Vivienda)</option>
            <option value="vehicular">🚗  Crédito Vehicular</option>
            <option value="personal">👤  Crédito Personal</option>
            <option value="comercial">🏢  Crédito Comercial / PyME</option>
          </select>
        </div>

        <div>
          <label class="lbl">Moneda</label>
          <select id="moneda" class="inp" onchange="onMonedaChange()">
            <option value="BOB">BOB — Boliviano</option>
            <option value="USD">USD — Dólar Americano</option>
            <option value="UFV">UFV — Unidad de Fomento a la Vivienda</option>
          </select>
        </div>

        <div>
          <label class="lbl">Monto del Préstamo</label>
          <div class="relative">
            <span id="currSym" class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-yellow-600">Bs.</span>
            <input type="number" id="monto" class="inp" style="padding-left: 2.75rem;" value="500000" min="1000" step="1000">
          </div>
          <input type="range" id="montoSlider" min="10000" max="5000000" step="10000" value="500000" class="mt-2"
                 oninput="syncVal('montoSlider','monto')">
          <div class="flex justify-between text-xs text-blue-400 mt-1">
            <span>Bs. 10k</span><span id="montoLbl" class="font-semibold text-yellow-600">Bs. 500k</span><span>Bs. 5M</span>
          </div>
        </div>

        <div>
          <label class="lbl">Plazo del Crédito (años)</label>
          <input type="number" id="plazo" class="inp" value="15" min="1" max="30"
                 oninput="document.getElementById('plazoSlider').value=this.value; document.getElementById('plazoLbl').textContent=this.value+' años'">
          <input type="range" id="plazoSlider" min="1" max="30" value="15" class="mt-2"
                 oninput="syncVal('plazoSlider','plazo'); document.getElementById('plazoLbl').textContent=this.value+' años'">
          <div class="flex justify-between text-xs text-blue-400 mt-1">
            <span>1 año</span><span id="plazoLbl" class="font-semibold text-yellow-600">15 años</span><span>30 años</span>
          </div>
        </div>

        <div>
          <label class="lbl">Fecha del Primer Pago</label>
          <input type="date" id="fechaInicio" class="inp">
        </div>
      </div>
    </div>

    <div class="card-bg p-6">
      <h2 class="font-display text-xl font-semibold mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-yellow-50 flex items-center justify-center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8860B" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </span>
        Tipo de Tasa
      </h2>
      <div class="rate-tabs mb-5">
        <button class="rtab active" id="tab-fija"     onclick="setTasa('fija')">Fija</button>
        <button class="rtab"        id="tab-variable" onclick="setTasa('variable')">Variable</button>
        <button class="rtab"        id="tab-mixta"    onclick="setTasa('mixta')">Mixta</button>
      </div>

      <div id="pnl-fija" class="space-y-3">
        <div>
          <label class="lbl">Tasa Nominal Anual (%)</label>
          <input type="number" id="tasaFija" class="inp" value="7.50" min="0" max="30" step="0.01">
          <p class="text-xs text-blue-400 mt-1">Ingresa el porcentaje anual. Ej: 7.5 = 7.5%</p>
        </div>
      </div>

      <div id="pnl-variable" class="space-y-3 hidden">
        <div class="bg-yellow-50 rounded-xl p-3 text-xs text-yellow-800">
          ⚡ Tasa = <strong>TRE + Spread (margen del banco)</strong>
        </div>
        <div>
          <label class="lbl">TRE Actual (% anual)</label>
          <div class="relative">
            <input type="number" id="treVar" class="inp pr-16" value="2.95" min="0" max="20" step="0.01"
                   oninput="calcTasaVar()">
            <span class="absolute right-3 top-1/2 -translate-y-1/2 tre-pill py-0.5 text-[10px]">BCB</span>
          </div>
          <p class="text-xs text-blue-400 mt-1">📡 Valor manual · Puede conectarse automáticamente a la BCB.</p>
        </div>
        <div>
          <label class="lbl">Spread / Margen del Banco (%)</label>
          <input type="number" id="spreadVar" class="inp" value="4.55" min="0" max="20" step="0.01"
                 oninput="calcTasaVar()">
        </div>
        <div class="bg-blue-50 rounded-xl p-3 text-xs text-blue-700">
          Tasa efectiva = TRE <span id="treVarD">2.95</span>% + Spread <span id="spreadVarD">4.55</span>% =
          <strong class="text-sm" id="efecVar">7.50%</strong>
        </div>
      </div>

      <div id="pnl-mixta" class="space-y-3 hidden">
        <div class="bg-blue-50 rounded-xl p-3 text-xs text-blue-700">
          💡 Período inicial con <strong>tasa fija</strong>, luego cambia a <strong>TRE + margen</strong>.
        </div>
        <div>
          <label class="lbl">Tasa Fija Inicial (%)</label>
          <input type="number" id="tasaMixtaFija" class="inp" value="6.50" min="0" max="30" step="0.01">
        </div>
        <div>
          <label class="lbl">Duración del Período Fijo (años)</label>
          <input type="number" id="aniosFijos" class="inp" value="5" min="1" max="29">
          <p class="text-xs text-blue-400 mt-1">El resto del plazo pasará a tasa variable.</p>
        </div>
        <div class="border-t border-gray-100 pt-4">
          <p class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-3">Fase 2 · Tasa Variable</p>
          <div class="space-y-3">
            <div>
              <label class="lbl">TRE Proyectada (%)</label>
              <input type="number" id="treMixta" class="inp" value="2.95" min="0" max="20" step="0.01"
                     oninput="calcTasaMixta()">
            </div>
            <div>
              <label class="lbl">Spread / Margen (%)</label>
              <input type="number" id="spreadMixta" class="inp" value="5.05" min="0" max="20" step="0.01"
                     oninput="calcTasaMixta()">
            </div>
            <div class="bg-yellow-50 rounded-xl p-3 text-xs text-yellow-800">
              Tasa Fase 2 = TRE + Spread = <strong id="mixFase2">8.00%</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card-bg p-6">
      <h2 class="font-display text-xl font-semibold mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-green-50 flex items-center justify-center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#065F46" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        Seguros
      </h2>
      <div class="space-y-5">
        <div class="flex items-start gap-3">
          <input type="checkbox" id="chkDesgrav" checked class="mt-1 w-4 h-4 rounded" style="accent-color:#B8860B">
          <div class="flex-1">
            <label for="chkDesgrav" class="lbl cursor-pointer">Seguro de Desgravamen</label>
            <div class="flex gap-2 items-center">
              <input type="number" id="tasaDesgrav" class="inp" value="0.083" min="0" max="2" step="0.001">
              <span class="text-xs text-blue-400 whitespace-nowrap">% mensual / saldo</span>
            </div>
            <p class="text-xs text-blue-400 mt-1">Calculado mensualmente sobre el saldo insoluto.</p>
          </div>
        </div>
        <div id="segOtroWrap" class="flex items-start gap-3">
          <input type="checkbox" id="chkSegOtro" checked class="mt-1 w-4 h-4 rounded" style="accent-color:#B8860B">
          <div class="flex-1">
            <label for="chkSegOtro" class="lbl cursor-pointer" id="lblSegOtro">Seguro de Inmueble</label>
            <div class="flex gap-2 items-center">
              <input type="number" id="tasaSegOtro" class="inp" value="0.022" min="0" max="5" step="0.001">
              <span class="text-xs text-blue-400 whitespace-nowrap">% mensual / saldo</span>
            </div>
            <p class="text-xs text-blue-400 mt-1">Calculado mensualmente sobre el saldo insoluto.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="card-bg p-6">
      <h2 class="font-display text-xl font-semibold mb-4 flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-purple-50 flex items-center justify-center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </span>
        Análisis de Capacidad
      </h2>
      <div>
        <label class="lbl">Ingreso Mensual Neto</label>
        <div class="relative">
          <span id="currSym2" class="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-bold text-yellow-600">Bs.</span>
          <input type="number" id="ingreso" class="inp" style="padding-left: 2.75rem;" placeholder="Ej: 8,000" min="0">
        </div>
        <p class="text-xs text-blue-400 mt-1">Opcional. Tu sueldo para el análisis de riesgo bancario (estándar ASFI).</p>
      </div>
    </div>

    <button class="btn-gold" onclick="calcular()">
      ⚡&nbsp;Calcular Amortización
    </button>

  </div>

  <div class="xl:col-span-3" id="colResultados">

    <div id="placeholder" class="card-bg p-14 flex flex-col items-center justify-center text-center gap-4" style="min-height:320px">
      <div class="w-20 h-20 rounded-full gold-bg flex items-center justify-center opacity-20">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
          <path d="M9 7H6a2 2 0 00-2 2v9a2 2 0 002 2h9a2 2 0 002-2v-3"/>
          <path d="M9 15h3l8.5-8.5a1.5 1.5 0 00-3-3L9 12v3"/><path d="M16 5l3 3"/>
        </svg>
      </div>
      <div>
        <h3 class="font-display text-2xl opacity-40">Configure el crédito</h3>
        <p class="text-blue-400 text-sm mt-1 opacity-50">Complete los parámetros y presione <strong>Calcular</strong><br>para ver la tabla de amortización completa.</p>
      </div>
    </div>

    <div id="resultados" class="hidden space-y-5">

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sum-grid">
        <div class="sum-card hero-bg text-white fade-up d1">
          <p class="text-blue-300 text-xs uppercase tracking-wider mb-1">Cuota Cap+Int</p>
          <p class="font-amount text-2xl" id="sC">—</p>
          <p class="text-blue-400 text-xs mt-1">Sistema Francés</p>
        </div>
        <div class="sum-card gold-bg text-white fade-up d2">
          <p class="text-yellow-100 text-xs uppercase tracking-wider mb-1">Cuota Total</p>
          <p class="font-amount text-2xl" id="sCT">—</p>
          <p class="text-yellow-100 text-xs mt-1">Incluye seguros</p>
        </div>
        <div class="sum-card card-bg border border-gray-100 fade-up d3">
          <p class="text-blue-400 text-xs uppercase tracking-wider mb-1">Total Intereses</p>
          <p class="font-amount text-2xl text-navy-900" id="sI">—</p>
          <p class="text-blue-400 text-xs mt-1" id="sIPct">% del capital</p>
        </div>
        <div class="sum-card card-bg border border-gray-100 fade-up d4">
          <p class="text-blue-400 text-xs uppercase tracking-wider mb-1">Total a Pagar</p>
          <p class="font-amount text-2xl text-navy-900" id="sTP">—</p>
          <p class="text-blue-400 text-xs mt-1">Capital+Int+Seg</p>
        </div>
      </div>

      <div class="card-bg p-5 fade-up" id="chartCard">
        <h3 class="font-display text-lg font-semibold mb-4">Composición del Pago</h3>
        <div class="flex flex-col sm:flex-row items-center gap-6">
          <svg id="donutSvg" width="140" height="140" viewBox="0 0 140 140" class="flex-shrink-0">
            <circle cx="70" cy="70" r="52" fill="none" stroke="#EEF2FA" stroke-width="22"/>
            <circle id="dArc1" cx="70" cy="70" r="52" fill="none" stroke="#0A1F42" stroke-width="22"
                    stroke-dasharray="0 327" stroke-dashoffset="81.75" transform="rotate(-90 70 70)"
                    style="transition:stroke-dasharray .6s ease"/>
            <circle id="dArc2" cx="70" cy="70" r="52" fill="none" stroke="#D4A843" stroke-width="22"
                    stroke-dasharray="0 327" stroke-dashoffset="81.75" transform="rotate(-90 70 70)"
                    style="transition:stroke-dasharray .6s ease"/>
            <circle id="dArc3" cx="70" cy="70" r="52" fill="none" stroke="#93C5FD" stroke-width="22"
                    stroke-dasharray="0 327" stroke-dashoffset="81.75" transform="rotate(-90 70 70)"
                    style="transition:stroke-dasharray .6s ease"/>
            <text x="70" y="66" text-anchor="middle" class="donut-label" id="donutPct">—</text>
            <text x="70" y="80" text-anchor="middle" class="donut-sub">CAPITAL</text>
          </svg>
          <div class="space-y-2 w-full">
            <div class="flex items-center justify-between text-sm">
              <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm" style="background:#0A1F42"></span>Capital Amortizado</div>
              <div class="flex items-center gap-3">
                <span class="font-semibold" id="lgCap">—</span>
                <span class="text-blue-400 text-xs w-10 text-right" id="lgCapPct">—</span>
              </div>
            </div>
            <div class="pbar"><div class="pbar-fill" id="barCap" style="background:#0A1F42;width:0%"></div></div>
            <div class="flex items-center justify-between text-sm mt-2">
              <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm" style="background:#D4A843"></span>Intereses</div>
              <div class="flex items-center gap-3">
                <span class="font-semibold" id="lgInt">—</span>
                <span class="text-blue-400 text-xs w-10 text-right" id="lgIntPct">—</span>
              </div>
            </div>
            <div class="pbar"><div class="pbar-fill" id="barInt" style="background:#D4A843;width:0%"></div></div>
            <div class="flex items-center justify-between text-sm mt-2" id="lgSegRow">
              <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-sm" style="background:#93C5FD"></span>Seguros</div>
              <div class="flex items-center gap-3">
                <span class="font-semibold" id="lgSeg">—</span>
                <span class="text-blue-400 text-xs w-10 text-right" id="lgSegPct">—</span>
              </div>
            </div>
            <div class="pbar"><div class="pbar-fill" id="barSeg" style="background:#93C5FD;width:0%"></div></div>
          </div>
        </div>
      </div>

      <div id="capSection" class="card-bg p-5 hidden fade-up">
        <h3 class="font-display text-lg font-semibold mb-3">📊 Análisis de Capacidad de Pago</h3>
        <div id="capContent"></div>
      </div>

      <div id="faseInd" class="hidden flex gap-5 text-xs text-blue-500 font-semibold">
        <span><span class="phase-dot p1-dot"></span>Fase 1 – Tasa Fija</span>
        <span><span class="phase-dot p2-dot"></span>Fase 2 – Tasa Variable (TRE + Spread)</span>
      </div>

      <div class="card-bg p-5 fade-up">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
          <div>
            <h3 class="font-display text-xl font-semibold">Tabla de Amortización</h3>
            <p class="text-blue-400 text-xs" id="tblMeta">Sistema Francés</p>
          </div>
          <div class="flex gap-2">
            <button class="btn-sm" onclick="exportCSV()">⬇ CSV</button>
            <button class="btn-sm" onclick="toggleAll()" id="btnAll">Ver todo</button>
          </div>
        </div>
        <div class="tbl-wrap">
          <table class="amort-tbl">
            <thead>
              <tr>
                <th>#</th>
                <th style="text-align:left">Fecha</th>
                <th>Capital</th>
                <th>Interés</th>
                <th>Desgravamen</th>
                <th>Seg. Otro</th>
                <th>Cuota Total</th>
                <th>Saldo</th>
              </tr>
            </thead>
            <tbody id="tblBody"></tbody>
            <tfoot id="tblFoot"></tfoot>
          </table>
        </div>
        <div class="flex items-center justify-between mt-4 flex-wrap gap-2" id="pgSection">
          <p class="text-xs text-blue-400" id="pgInfo">—</p>
          <div class="flex gap-2">
            <button class="btn-sm" id="btnPrev" onclick="cambiarPg(-1)">← Anterior</button>
            <button class="btn-sm" id="btnNext" onclick="cambiarPg(1)">Siguiente →</button>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>
</main>

<script is:inline>
"use strict";

const DB_CONFIG = {
  TRE:           2.95,
  UFV_DIA:       2.3847,
  LIMITE_OPTIMO: 25,
  LIMITE_MAXIMO: 30,
};

const ST = {
  tipoTasa:  'fija',
  tabla:     [],
  pagina:    1,
  porPagina: 24,
  verTodo:   false,
  moneda:    'BOB',
  params:    {},
};

const $ = id => document.getElementById(id);

document.addEventListener('DOMContentLoaded', () => {
  const d = new Date();
  d.setMonth(d.getMonth() + 1);
  d.setDate(1);
  $('fechaInicio').value = d.toISOString().slice(0, 10);
  $('treVar').value   = window.TRE_VIGENTE || DB_CONFIG.TRE;
  $('treMixta').value = window.TRE_VIGENTE || DB_CONFIG.TRE;
  const hdrTRE = $('hdrTRE');
  if (hdrTRE) hdrTRE.textContent = DB_CONFIG.TRE;
  $('monto').addEventListener('input', () => {
    const v = +$('monto').value;
    $('montoSlider').value = Math.min(Math.max(v, 10000), 5000000);
    $('montoLbl').textContent = fmtCompact(v, ST.moneda);
  });
  $('montoSlider').addEventListener('input', () => {
    const v = +$('montoSlider').value;
    $('monto').value = v;
    $('montoLbl').textContent = fmtCompact(v, ST.moneda);
  });
  ['treVar', 'spreadVar'].forEach(id => $(id)?.addEventListener('input', calcTasaVar));
  ['treMixta', 'spreadMixta'].forEach(id => $(id)?.addEventListener('input', calcTasaMixta));
  actualizarUI();
  calcTasaVar();
  calcTasaMixta();
});

function setTasa(tipo) {
  ST.tipoTasa = tipo;
  ['fija', 'variable', 'mixta'].forEach(t => {
    $(`tab-${t}`).classList.toggle('active', t === tipo);
    $(`pnl-${t}`).classList.toggle('hidden', t !== tipo);
  });
}

function actualizarUI() {
  const tipo = $('tipoCredito').value;
  const cfgs = {
    hipotecario: { lbl: 'Seguro de Inmueble',  tasa: '0.022', show: true  },
    vehicular:   { lbl: 'Seguro de Vehículo',  tasa: '0.030', show: true  },
    personal:    { lbl: 'Seguro de Vida',       tasa: '0.015', show: false },
    comercial:   { lbl: 'Seguro Comercial',     tasa: '0.018', show: false },
  };
  const cfg = cfgs[tipo];
  $('lblSegOtro').textContent = cfg.lbl;
  $('tasaSegOtro').value      = cfg.tasa;
  $('segOtroWrap').classList.toggle('hidden', !cfg.show);
  $('chkSegOtro').checked     = cfg.show;
}

function onMonedaChange() {
  ST.moneda = $('moneda').value;
  const sym = { BOB: 'Bs.', USD: 'US$', UFV: 'UFV' };
  $('currSym').textContent  = sym[ST.moneda];
  $('currSym2').textContent = sym[ST.moneda];
  $('montoLbl').textContent = fmtCompact(+$('monto').value, ST.moneda);
}

function syncVal(sliderId, inputId) {
  $(inputId).value = $(sliderId).value;
}

function calcTasaVar() {
  const tre    = +($('treVar')?.value    || 0);
  const spread = +($('spreadVar')?.value || 0);
  const ef = (tre + spread).toFixed(2);
  $('treVarD').textContent    = tre;
  $('spreadVarD').textContent = spread;
  $('efecVar').textContent    = ef + '%';
}

function calcTasaMixta() {
  const tre    = +($('treMixta')?.value    || 0);
  const spread = +($('spreadMixta')?.value || 0);
  $('mixFase2').textContent = (tre + spread).toFixed(2) + '%';
}

function pmt(pv, r, n) {
  if (n <= 0) return 0;
  if (r === 0) return pv / n;
  return pv * r / (1 - Math.pow(1 + r, -n));
}

function generarTabla(p) {
  const totalMeses = p.plazoAnios * 12;
  const tabla = [];
  let saldo = p.monto;
  let r1, r2 = null, mesesF1;
  if (p.tipoTasa === 'fija') {
    r1      = p.tasaFija / 100 / 12;
    mesesF1 = totalMeses;
  } else if (p.tipoTasa === 'variable') {
    r1      = (p.treVar + p.spreadVar) / 100 / 12;
    mesesF1 = totalMeses;
  } else {
    r1      = p.tasaMixtaFija / 100 / 12;
    r2      = (p.treMixta + p.spreadMixta) / 100 / 12;
    mesesF1 = Math.min(p.aniosFijos * 12, totalMeses - 1);
  }
  const PMT1 = pmt(p.monto, r1, totalMeses);
  let PMT2   = null;
  let fecha  = new Date(p.fechaInicio + 'T00:00:00');
  for (let i = 1; i <= totalMeses; i++) {
    fecha = new Date(fecha.getFullYear(), fecha.getMonth() + 1, fecha.getDate());
    const fase2  = (p.tipoTasa === 'mixta') && (i > mesesF1);
    const rMes   = fase2 ? r2 : r1;
    if (fase2 && i === mesesF1 + 1) PMT2 = pmt(saldo, r2, totalMeses - mesesF1);
    const cuotaCI = fase2 ? PMT2 : PMT1;
    const interes = saldo * rMes;
    let   capital = cuotaCI - interes;
    if (i === totalMeses || capital >= saldo) capital = saldo;
    const segDesgrav = p.chkDesgrav ? saldo * (p.tasaDesgrav / 100) : 0;
    const segOtro    = p.chkSegOtro ? saldo * (p.tasaSegOtro  / 100) : 0;
    const cuotaTotal = capital + interes + segDesgrav + segOtro;
    saldo = Math.max(0, saldo - capital);
    tabla.push({ nro: i, fecha: fmtFecha(fecha), capital, interes, segDesgrav, segOtro, cuotaCI: capital + interes, cuotaTotal, saldo, fase2 });
    if (saldo === 0) break;
  }
  return tabla;
}

function calcular() {
  const tipoCredito = $('tipoCredito').value;
  const moneda      = $('moneda').value;
  const monto       = parseFloat($('monto').value);
  const plazoAnios  = parseInt($('plazo').value);
  const fechaInicio = $('fechaInicio').value;
  if (!monto      || monto     <= 0) return alert('Ingrese un monto válido.');
  if (!plazoAnios || plazoAnios <= 0) return alert('Ingrese un plazo válido (1–30 años).');
  if (!fechaInicio)                   return alert('Seleccione la fecha del primer pago.');
  let tasaFija = 0, treVar = 0, spreadVar = 0;
  let tasaMixtaFija = 0, aniosFijos = 0, treMixta = 0, spreadMixta = 0;
  if (ST.tipoTasa === 'fija') {
    tasaFija = parseFloat($('tasaFija').value) || 0;
  } else if (ST.tipoTasa === 'variable') {
    treVar    = parseFloat($('treVar').value)    || DB_CONFIG.TRE;
    spreadVar = parseFloat($('spreadVar').value) || 0;
  } else {
    tasaMixtaFija = parseFloat($('tasaMixtaFija').value) || 0;
    aniosFijos    = parseInt($('aniosFijos').value)       || 0;
    treMixta      = parseFloat($('treMixta').value)       || DB_CONFIG.TRE;
    spreadMixta   = parseFloat($('spreadMixta').value)    || 0;
    if (aniosFijos <= 0 || aniosFijos >= plazoAnios)
      return alert(`El período fijo debe estar entre 1 y ${plazoAnios - 1} años.`);
  }
  const chkDesgrav  = $('chkDesgrav').checked;
  const tasaDesgrav = parseFloat($('tasaDesgrav').value) || 0;
  const chkSegOtro  = $('chkSegOtro').checked && !$('segOtroWrap').classList.contains('hidden');
  const tasaSegOtro = parseFloat($('tasaSegOtro').value) || 0;
  const params = { monto, plazoAnios, tipoTasa: ST.tipoTasa, tasaFija, treVar, spreadVar, tasaMixtaFija, aniosFijos, treMixta, spreadMixta, chkDesgrav, tasaDesgrav, chkSegOtro, tasaSegOtro, fechaInicio, tipoCredito, moneda };
  ST.params  = params;
  ST.moneda  = moneda;
  ST.tabla   = generarTabla(params);
  ST.pagina  = 1;
  ST.verTodo = false;
  mostrarResultados();
}

function mostrarResultados() {
  const t = ST.tabla;
  const p = ST.params;
  if (!t.length) return;
  const r0  = t[0];
  const tot = key => t.reduce((s, r) => s + r[key], 0);
  const totalInt   = tot('interes');
  const totalDesgr = tot('segDesgrav');
  const totalOtro  = tot('segOtro');
  const totalPagar = p.monto + totalInt + totalDesgr + totalOtro;
  const f = n => fmtMoneda(n, ST.moneda);
  $('sC').textContent    = f(r0.cuotaCI);
  $('sCT').textContent   = f(r0.cuotaTotal);
  $('sI').textContent    = f(totalInt);
  $('sIPct').textContent = ((totalInt / p.monto) * 100).toFixed(1) + '% del capital';
  $('sTP').textContent   = f(totalPagar);
  const lblTasa = {
    fija:     `Tasa Fija ${p.tasaFija}%`,
    variable: `TRE (${p.treVar}%) + Spread (${p.spreadVar}%) = ${(p.treVar + p.spreadVar).toFixed(2)}%`,
    mixta:    `Mixta — Fija ${p.tasaMixtaFija}% (${p.aniosFijos}a) → Variable ${(p.treMixta + p.spreadMixta).toFixed(2)}%`,
  };
  $('tblMeta').textContent = `Sistema Francés · ${lblTasa[ST.tipoTasa]} · ${t.length} cuotas`;
  actualizarDonut(r0);
  $('faseInd').classList.toggle('hidden', ST.tipoTasa !== 'mixta');
  const ingreso = parseFloat($('ingreso').value) || 0;
  if (ingreso > 0) mostrarCapacidad(r0.cuotaTotal, ingreso);
  else $('capSection').classList.add('hidden');
  renderTabla();
  $('placeholder').classList.add('hidden');
  $('resultados').classList.remove('hidden');
  if (window.innerWidth < 1280) setTimeout(() => $('resultados').scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
}

function actualizarDonut(r0) {
  const total  = r0.cuotaTotal;
  const capPct = total ? r0.capital / total : 0;
  const intPct = total ? r0.interes / total : 0;
  const segPct = total ? (r0.segDesgrav + r0.segOtro) / total : 0;
  const C = 2 * Math.PI * 52;
  const seg1 = capPct * C;
  const seg2 = intPct * C;
  const seg3 = segPct * C;
  $('dArc1').setAttribute('stroke-dasharray', `${seg1} ${C - seg1}`);
  $('dArc2').setAttribute('stroke-dasharray', `${seg2} ${C - seg2}`);
  $('dArc2').setAttribute('stroke-dashoffset', -seg1 + 81.75);
  $('dArc3').setAttribute('stroke-dasharray', `${seg3} ${C - seg3}`);
  $('dArc3').setAttribute('stroke-dashoffset', -(seg1 + seg2) + 81.75);
  $('donutPct').textContent = (capPct * 100).toFixed(0) + '%';
  const f = n => fmtMoneda(n, ST.moneda);
  $('lgCap').textContent    = f(r0.capital);
  $('lgCapPct').textContent = (capPct * 100).toFixed(1) + '%';
  $('barCap').style.width   = (capPct * 100) + '%';
  $('lgInt').textContent    = f(r0.interes);
  $('lgIntPct').textContent = (intPct * 100).toFixed(1) + '%';
  $('barInt').style.width   = (intPct * 100) + '%';
  $('lgSeg').textContent    = f(r0.segDesgrav + r0.segOtro);
  $('lgSegPct').textContent = (segPct * 100).toFixed(1) + '%';
  $('barSeg').style.width   = (segPct * 100) + '%';
}

function mostrarCapacidad(cuota, ingreso) {
  const pct = (cuota / ingreso) * 100;
  $('capSection').classList.remove('hidden');
  let badgeCls, borderCls, bgCls, textCls, titulo, msg;
  if (pct <= DB_CONFIG.LIMITE_OPTIMO) {
    badgeCls = 'badge-ok';    borderCls = 'border-green-500'; bgCls = 'bg-green-50'; textCls = 'text-green-800';
    titulo = '✅ Capacidad Óptima';
    msg    = 'Tu cuota está dentro del límite óptimo del 25%. Los bancos consideran esta situación de <strong>bajo riesgo crediticio</strong>. Tienes excelentes probabilidades de aprobación.';
  } else if (pct <= DB_CONFIG.LIMITE_MAXIMO) {
    badgeCls = 'badge-warn';   borderCls = 'border-yellow-500'; bgCls = 'bg-yellow-50'; textCls = 'text-yellow-800';
    titulo = '⚠️ Capacidad Aceptable';
    msg    = 'Tu cuota supera el 25% pero está dentro del límite del 30%. Puede aprobarse con <strong>análisis adicional</strong>. Considera ampliar el plazo o reducir el monto.';
  } else {
    badgeCls = 'badge-danger'; borderCls = 'border-red-500'; bgCls = 'bg-red-50'; textCls = 'text-red-800';
    titulo = '❌ Riesgo Alto';
    msg    = 'Tu cuota supera el 30% de tus ingresos. La mayoría de entidades financieras <strong>rechazarían este crédito</strong>. Reduce el monto o extiende el plazo.';
  }
  const f = n => fmtMoneda(n, ST.moneda);
  const bw = Math.min(pct, 100);
  const bc = pct <= 25 ? '#22C55E' : pct <= 30 ? '#F59E0B' : '#EF4444';
  const libre = Math.max(0, ingreso - cuota);
  $('capContent').innerHTML = `
    <div class="flex flex-col sm:flex-row sm:items-start gap-5">
      <div class="flex-1">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold">Cuota / Ingreso</span>
          <span class="px-3 py-1 rounded-full text-sm font-bold ${badgeCls}">${pct.toFixed(1)}%</span>
        </div>
        <div class="pbar mb-1"><div class="pbar-fill" style="width:${bw}%;background:${bc}"></div></div>
        <div class="flex justify-between text-xs text-blue-400 mt-1">
          <span>0%</span><span class="text-green-600 font-semibold">25% Óptimo</span>
          <span class="text-yellow-600 font-semibold">30% Límite</span><span>50%+</span>
        </div>
      </div>
      <div class="flex flex-col items-center text-center sm:w-36">
        <p class="text-3xl mb-1">${pct <= 25 ? '🟢' : pct <= 30 ? '🟡' : '🔴'}</p>
        <p class="font-semibold text-sm leading-tight">${titulo.replace(/[✅⚠️❌]\s*/, '')}</p>
      </div>
    </div>
    <div class="mt-4 bg-gray-50 rounded-xl p-4 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
      <div><p class="text-blue-400 text-xs">Ingreso Mensual</p><p class="font-semibold">${f(ingreso)}</p></div>
      <div><p class="text-blue-400 text-xs">Cuota Total</p><p class="font-semibold">${f(cuota)}</p></div>
      <div><p class="text-blue-400 text-xs">% del Ingreso</p><p class="font-semibold ${pct>30?'text-red-600':pct>25?'text-yellow-600':'text-green-600'}">${pct.toFixed(2)}%</p></div>
      <div><p class="text-blue-400 text-xs">Límite 25% (Óptimo)</p><p class="font-semibold">${f(ingreso*0.25)}</p></div>
      <div><p class="text-blue-400 text-xs">Límite 30% (Máximo)</p><p class="font-semibold">${f(ingreso*0.30)}</p></div>
      <div><p class="text-blue-400 text-xs">Ingreso Disponible</p><p class="font-semibold ${libre===0?'text-red-600':'text-green-600'}">${f(libre)}</p></div>
    </div>
    <div class="mt-3 p-3 rounded-xl border-l-4 ${borderCls} ${bgCls}">
      <p class="text-sm ${textCls}">${msg}</p>
    </div>`;
}

function renderTabla() {
  const t    = ST.tabla;
  const body = $('tblBody');
  const foot = $('tblFoot');
  let filas;
  if (ST.verTodo) {
    filas = t;
  } else {
    const ini = (ST.pagina - 1) * ST.porPagina;
    filas = t.slice(ini, ini + ST.porPagina);
  }
  body.innerHTML = filas.map(r => `
    <tr class="${r.fase2 ? 'fase2' : ''}">
      <td><span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;font-size:11px;font-weight:700;background:${r.fase2?'rgba(212,168,67,.18)':'#EEF4FF'};color:${r.fase2?'#A87420':'#0A1F42'}">${r.nro}</span></td>
      <td>${r.fecha}</td>
      <td>${fmtNum(r.capital)}</td>
      <td>${fmtNum(r.interes)}</td>
      <td>${fmtNum(r.segDesgrav)}</td>
      <td>${fmtNum(r.segOtro)}</td>
      <td><strong>${fmtNum(r.cuotaTotal)}</strong></td>
      <td>${fmtNum(r.saldo)}</td>
    </tr>`).join('');
  const sm = k => t.reduce((s, r) => s + r[k], 0);
  foot.innerHTML = `<tr><td colspan="2">TOTALES</td><td>${fmtNum(sm('capital'))}</td><td>${fmtNum(sm('interes'))}</td><td>${fmtNum(sm('segDesgrav'))}</td><td>${fmtNum(sm('segOtro'))}</td><td><strong>${fmtNum(sm('cuotaTotal'))}</strong></td><td>—</td></tr>`;
  const total = t.length;
  const ini   = (ST.pagina - 1) * ST.porPagina + 1;
  const fin   = Math.min(ST.pagina * ST.porPagina, total);
  if (ST.verTodo) {
    $('pgInfo').textContent    = `Mostrando todas las ${total} cuotas`;
    $('btnPrev').style.display = 'none';
    $('btnNext').style.display = 'none';
  } else {
    $('pgInfo').textContent    = `Cuotas ${ini}–${fin} de ${total}`;
    $('btnPrev').style.display = '';
    $('btnNext').style.display = '';
    $('btnPrev').disabled      = ST.pagina === 1;
    $('btnNext').disabled      = fin >= total;
  }
}

function cambiarPg(dir) {
  const max = Math.ceil(ST.tabla.length / ST.porPagina);
  ST.pagina = Math.max(1, Math.min(ST.pagina + dir, max));
  renderTabla();
  $('resultados').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function toggleAll() {
  ST.verTodo = !ST.verTodo;
  $('btnAll').textContent = ST.verTodo ? 'Paginar' : 'Ver todo';
  renderTabla();
}

function exportCSV() {
  if (!ST.tabla.length) return;
  const p = ST.params;
  const meta = [
    [`SimuladordeCreditos.com — Tabla de Amortización Sistema Francés`],
    [`Tipo:${p.tipoCredito}`,`Monto:${p.monto} ${ST.moneda}`,`Plazo:${p.plazoAnios} años`,`Tasa:${ST.tipoTasa}`,`Fecha:${new Date().toLocaleDateString('es-BO')}`],
    [],
  ];
  const hdr  = ['Cuota','Fecha','Capital','Interes','Seg.Desgravamen','Seg.Otro','Cuota Cap+Int','Cuota Total','Saldo','Fase'];
  const rows = ST.tabla.map(r => [r.nro,r.fecha,r.capital.toFixed(2),r.interes.toFixed(2),r.segDesgrav.toFixed(2),r.segOtro.toFixed(2),r.cuotaCI.toFixed(2),r.cuotaTotal.toFixed(2),r.saldo.toFixed(2),r.fase2?2:1]);
  const csv  = [...meta.map(r=>r.join(',')),hdr.join(','),...rows.map(r=>r.join(','))].join('\n');
  const blob = new Blob(['﻿'+csv],{type:'text/csv;charset=utf-8;'});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `amortizacion_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

function fmtNum(n) { return n.toLocaleString('es-BO',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtMoneda(n,moneda='BOB') {
  const s={BOB:'Bs. ',USD:'US$ ',UFV:'UFV '}[moneda]||'Bs. ';
  if(n>=1_000_000) return s+(n/1_000_000).toFixed(3)+'M';
  if(n>=100_000)   return s+(n/1_000).toFixed(1)+'k';
  return s+fmtNum(n);
}
function fmtCompact(n,moneda='BOB') {
  const s={BOB:'Bs.',USD:'US$',UFV:'UFV'}[moneda]||'Bs.';
  if(n>=1_000_000) return `${s} ${(n/1_000_000).toFixed(2)}M`;
  if(n>=1_000)     return `${s} ${(n/1_000).toFixed(0)}k`;
  return `${s} ${n}`;
}
function fmtFecha(date) { return date.toLocaleDateString('es-BO',{day:'2-digit',month:'2-digit',year:'numeric'}); }
</script>

