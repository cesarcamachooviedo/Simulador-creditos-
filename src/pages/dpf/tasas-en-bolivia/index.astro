<!-- ══════════════════ JAVASCRIPT ══════════════════ -->
<script is:inline>
"use strict";

var ENTIDADES = [
  // Bancos Múltiples — tasas reales publicadas en sitios oficiales (feb 2026)
  { nombre:'BCP Digital',       tipo:'bancos', t30:null, t90:null,  t180:3.50, t360:4.00, tPlus:4.50, nota:'DPF 100% digital — apertura por app' },
  { nombre:'BCP Clásico',       tipo:'bancos', t30:null, t90:null,  t180:2.50, t360:3.00, tPlus:3.50, nota:'Apertura en sucursal' },
  { nombre:'BNB',               tipo:'bancos', t30:null, t90:null,  t180:null, t360:2.99, tPlus:4.00, nota:'4.00% desde 361 días' },
  { nombre:'BMSC',              tipo:'bancos', t30:null, t90:null,  t180:null, t360:4.10, tPlus:4.60, nota:'A 365 días' },
  { nombre:'Banco Unión',       tipo:'bancos', t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en bancounion.com.bo' },
  { nombre:'Banco BISA',        tipo:'bancos', t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en bisa.com' },
  { nombre:'Banco Económico',   tipo:'bancos', t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en baneco.com.bo' },
  { nombre:'Banco Ganadero',    tipo:'bancos', t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en bg.com.bo' },
  { nombre:'Banco Fortaleza',   tipo:'bancos', t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en bancofortaleza.com.bo' },
  // Bancos PYME — tasas reales publicadas (feb 2026)
  { nombre:'BancoSol',          tipo:'pyme',   t30:null, t90:null,  t180:null, t360:5.25, tPlus:6.00, nota:'DPF Sol Festivo — mejor tasa PYME', destacado:true },
  { nombre:'Banco FIE',         tipo:'pyme',   t30:null, t90:null,  t180:null, t360:5.00, tPlus:6.00, nota:'DPF+ hasta Bs. 200,000' },
  { nombre:'Banco Prodem',      tipo:'pyme',   t30:null, t90:null,  t180:null, t360:null, tPlus:null, nota:'Consultar tarifario en bancoprodem.com.bo' },
];

var currentTab = 'todos';

function ratePill(val, isBest) {
  if (val === null || val === undefined) return '<span style="font-size:11px;color:#94A3B8;font-style:italic;">Consultar</span>';
  if (isBest) return '<span class="rate-pill rate-best">★ ' + val.toFixed(2) + '%</span>';
  if (val >= 5) return '<span class="rate-pill rate-high">' + val.toFixed(2) + '%</span>';
  if (val >= 3) return '<span class="rate-pill rate-mid">' + val.toFixed(2) + '%</span>';
  return '<span class="rate-pill rate-low">' + val.toFixed(2) + '%</span>';
}

function tipoLabel(tipo) {
  var labels = { bancos:'<span class="badge-blue">Banco Múltiple</span>', pyme:'<span class="badge-purple">Banco PYME</span>', coops:'<span class="badge-green">Cooperativa</span>' };
  return labels[tipo] || tipo;
}

function renderTable(tab) {
  var filtered = tab === 'todos' ? ENTIDADES : ENTIDADES.filter(function(e) { return e.tipo === tab; });
  var vals360  = filtered.map(function(e) { return e.t360; }).filter(function(v) { return v !== null && v !== undefined; });
  var maxT360  = vals360.length ? Math.max.apply(null, vals360) : 0;

  var html = filtered.map(function(e) {
    var isBest360 = e.t360 !== null && e.t360 === maxT360;
    return '<tr class="' + (e.destacado ? 'destacado' : '') + '">' +
      '<td>' + e.nombre + (e.destacado ? ' <span style="font-size:10px;color:#D4A843;">★</span>' : '') + '</td>' +
      '<td>' + tipoLabel(e.tipo) + '</td>' +
      '<td>' + ratePill(e.t30,  false) + '</td>' +
      '<td>' + ratePill(e.t90,  false) + '</td>' +
      '<td>' + ratePill(e.t180, false) + '</td>' +
      '<td>' + ratePill(e.t360, isBest360) + '</td>' +
      '<td>' + ratePill(e.tPlus,false) + '</td>' +
      '<td style="font-size:11px;color:#94A3B8;font-style:italic;text-align:left;max-width:180px;">' + (e.nota || '') + '</td>' +
    '</tr>';
  }).join('');

  document.getElementById('ratesBody').innerHTML = html;
  renderRanking(filtered, maxT360);
}

function renderRanking(entities, maxVal) {
  var sorted = entities.slice().filter(function(e) { return e.t360 !== null; }).sort(function(a, b) { return b.t360 - a.t360; }).slice(0, 6);
  var html = sorted.map(function(e) {
    var pct = (e.t360 / maxVal) * 100;
    var color = e.tipo === 'coops' ? '#22C55E' : e.tipo === 'pyme' ? '#8B5CF6' : '#1D4ED8';
    return '<div>' +
      '<div class="rate-bar-wrap">' +
        '<span style="font-size:13px;font-weight:600;color:#0A1F42;min-width:160px;">' + e.nombre + '</span>' +
        '<div class="rate-bar"><div class="rate-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div></div>' +
        '<span class="font-mono-num font-bold text-sm" style="min-width:40px;text-align:right;color:' + color + ';">' + e.t360.toFixed(1) + '%</span>' +
      '</div>' +
    '</div>';
  }).join('');
  document.getElementById('rankingBars').innerHTML = html;
}

function showTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.cat-tab').forEach(function(btn) { btn.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  renderTable(tab);
}

document.addEventListener('DOMContentLoaded', function() {
  renderTable('todos');
});
</script>

</BaseLayout>