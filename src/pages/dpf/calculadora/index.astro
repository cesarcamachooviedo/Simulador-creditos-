<script is:inline>
"use strict";
var DPF = { moneda:'BOB', monto:50000, dias:90, tasa:4.50, titular:'persona' };
var FAQS = [
  { q:'¿Puedo retirar el dinero antes del vencimiento?', a:'Generalmente no, o implica penalidades. La mayoría de bancos bolivianos aplican la pérdida parcial o total de los intereses si retirás antes del plazo. Algunos ofrecen "DPF con liquidez" a tasas menores. Consultá con tu banco antes de contratar.' },
  { q:'¿El RC-IVA aplica en dólares también?', a:'Sí. El RC-IVA (13%) aplica tanto a DPFs en Bolivianos como en Dólares, siempre que el plazo sea de 3 años o menos. No hay distinción por moneda para esta retención.' },
  { q:'¿Qué pasa si el plazo es mayor a 3 años en BOB?', a:'Según la normativa boliviana, los DPFs en Bolivianos con plazo mayor a 3 años (más de 1080 días) están exentos del RC-IVA. Esto significa que el 100% del interés bruto es tuyo. Esta exención aplica únicamente para moneda nacional.' },
  { q:'¿Qué es el Fondo de Protección al Ahorrista (FOPA)?', a:'El FOPA cubre hasta UFV 250,000 (aproximadamente Bs. 596,000) por persona en cada entidad financiera regulada por la ASFI. Si la entidad quiebra, el Estado garantiza esa suma. Para montos mayores, considerá diversificar en más de un banco.' },
  { q:'¿Cuál es la diferencia entre DPF y Caja de Ahorro?', a:'La Caja de Ahorro te permite retirar en cualquier momento pero paga tasas bajas (1%–3% anual). El DPF bloquea tu dinero por un plazo fijo pero paga tasas mucho mayores. La clave es que el dinero del DPF no debe ser de emergencia.' },
  { q:'¿En qué banco conviene poner el DPF?', a:'Las Cooperativas de Ahorro y Crédito autorizadas por la ASFI y los Bancos PYME suelen ofrecer tasas más altas que los Bancos Múltiples. Revisá nuestra tabla comparativa de tasas para ver las opciones actuales.' },
];

document.addEventListener('DOMContentLoaded', function() { renderFAQs(); calcDPF(); });

function setTitular(tipo) {
  DPF.titular = tipo;
  var isEmpresa = tipo === 'empresa';

  var btnP = document.getElementById('btnPersona');
  var btnE = document.getElementById('btnEmpresa');
  var nota = document.getElementById('titularNota');

  if (isEmpresa) {
    btnE.style.background    = '#0A1F42';
    btnE.style.color         = '#fff';
    btnE.style.boxShadow     = '0 2px 8px rgba(10,31,66,.25)';
    btnP.style.background    = 'transparent';
    btnP.style.color         = '#4B6A9B';
    btnP.style.boxShadow     = 'none';
    nota.style.background    = 'rgba(34,197,94,.06)';
    nota.style.borderColor   = 'rgba(34,197,94,.25)';
    nota.style.color         = '#16A34A';
    nota.innerHTML = '<strong>Empresa / NIT Jurídico:</strong> exento de RC-IVA. Las empresas tributan por IUE, no por RC-IVA personal. Recibís el 100% del interés bruto.';
  } else {
    btnP.style.background    = '#0A1F42';
    btnP.style.color         = '#fff';
    btnP.style.boxShadow     = '0 2px 8px rgba(10,31,66,.25)';
    btnE.style.background    = 'transparent';
    btnE.style.color         = '#4B6A9B';
    btnE.style.boxShadow     = 'none';
    nota.style.background    = 'rgba(239,68,68,.06)';
    nota.style.borderColor   = 'rgba(239,68,68,.20)';
    nota.style.color         = '#DC2626';
    nota.innerHTML = '<strong>Persona Natural:</strong> sujeto a RC-IVA (13% sobre intereses). El banco retiene automáticamente.';
  }
  calcDPF();
}

function setPlazo(btn) {
  document.querySelectorAll('.plazo-pill').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  DPF.dias = parseInt(btn.getAttribute('data-dias'));
  var textos = {30:'30 días',60:'60 días',90:'90 días',180:'180 días (6 meses)',360:'360 días (1 año)',720:'720 días (2 años)',1080:'1,080 días (3 años)'};
  document.getElementById('plazoNota').innerHTML = 'Plazo seleccionado: <strong>' + (textos[DPF.dias] || DPF.dias + ' días') + '</strong>';
  calcDPF();
}

function onMonedaChange() {
  DPF.moneda = document.getElementById('dpfMoneda').value;
  var isBOB = DPF.moneda === 'BOB';
  document.getElementById('currSymbol').textContent = isBOB ? 'Bs.' : 'US$';
  var max = isBOB ? 500000 : 50000;
  var mid = isBOB ? 50000  : 5000;
  document.getElementById('dpfSlider').max   = max;
  document.getElementById('dpfSlider').value = mid;
  document.getElementById('dpfMonto').value  = mid;
  document.getElementById('sliderMin').textContent = isBOB ? 'Bs. 1k'  : 'US$ 100';
  document.getElementById('sliderMid').textContent = isBOB ? 'Bs. 50k' : 'US$ 5k';
  document.getElementById('sliderMax').textContent = isBOB ? 'Bs. 500k': 'US$ 50k';
  DPF.monto = mid;
  calcDPF();
}

function calcDPF() {
  var monto = parseFloat(document.getElementById('dpfMonto').value) || 0;
  var tasa  = parseFloat(document.getElementById('dpfTasa').value)  || 0;
  var dias  = DPF.dias;
  var mon   = document.getElementById('dpfMoneda').value;
  if (monto <= 0 || tasa <= 0) return;
  DPF.monto = monto; DPF.tasa = tasa; DPF.moneda = mon;
  document.getElementById('sliderMid').textContent = fmtCompact(monto, mon);
  document.getElementById('dpfSlider').value = monto;
  var interesBruto = monto * (tasa / 100) * (dias / 360);
  var esExentoEmpresa = DPF.titular === 'empresa';
  var esExentoPlazo   = (mon === 'BOB') && (dias > 1080);
  var esExento        = esExentoEmpresa || esExentoPlazo;

  var motivoExencion = esExentoEmpresa
    ? 'Empresa / NIT Jurídico — exento de RC-IVA (tributa por IUE)'
    : 'DPF en BOB mayor a 3 años — exento de RC-IVA por normativa';
  var rcIva     = esExento ? 0 : interesBruto * 0.13;
  var interesNeto = interesBruto - rcIva;
  var montoFinal  = monto + interesNeto;
  var tirNeta = (interesNeto / monto) * (360 / dias) * 100;
  var f   = function(n) { return (mon==='BOB'?'Bs. ':'US$ ') + n.toLocaleString('es-BO',{minimumFractionDigits:2,maximumFractionDigits:2}); };
  var pct = function(n) { return n.toFixed(2)+'%'; };
  set('rNetoBig', f(interesNeto));
  set('rBruto',   f(interesBruto));
  set('rRCIVA',   esExento ? 'Exento' : f(rcIva));
  set('rTotal',   f(montoFinal));
  set('rTIR',     pct(tirNeta));
  var td = {30:'30 días',60:'60 días',90:'90 días',180:'180 días',360:'360 días (1 año)',720:'2 años (720 días)',1080:'3 años (1,080 días)'};
  set('tMonto', f(monto));
  set('tPlazo', td[dias] || dias+' días');
  set('tTasa',  pct(tasa));
  set('tBruto', f(interesBruto));
  set('tRCIVA', esExento ? 'Exento (BOB > 3 años)' : '− '+f(rcIva)+' (13%)');
  set('tNeto',  f(interesNeto));
  set('tFinal', f(montoFinal));
  document.getElementById('rcIvaNota').textContent = esExento
    ? '* ' + motivoExencion + '. Verificá con tu entidad financiera.'
    : '* El banco retiene el RC-IVA (13%) automáticamente al momento del vencimiento.';
  document.getElementById('alertaExencion').classList.toggle('hidden', !esExento);
  var maxTasa = Math.max(tasa, 10);
  document.getElementById('cmpDPFbar').style.width = Math.min((tasa/maxTasa)*100,100)+'%';
  document.getElementById('cmpDPFpct').textContent = pct(tasa);
  var ahorroCuenta = monto * 0.02 * (dias / 360);
  var diferencia   = interesNeto - ahorroCuenta;
  document.getElementById('cmpMensaje').textContent =
    'Con este DPF ganás ' + f(diferencia) + ' más que en una cuenta de ahorro al 2% anual en el mismo plazo.';
  var mensualBruto = monto * (tasa / 100) / 12;
  var mensualRCIVA = esExento ? 0 : mensualBruto * 0.13;
  var mensualNeto  = mensualBruto - mensualRCIVA;
  set('rMensual',      f(mensualNeto));
  set('rMensualBruto', f(mensualBruto));
  set('rMensualRCIVA', esExento ? 'Exento' : f(mensualRCIVA));
  set('rMensualNeto',  f(mensualNeto));
  document.getElementById('rMensualNota').textContent = esExento
    ? '* Exento de RC-IVA. El banco te paga el 100% del interés mensual.'
    : '* El banco retiene el RC-IVA (13%) también en los pagos mensuales.';

  var sliderMaxVal = mon === 'BOB' ? 10000000 : 50000;
  document.getElementById('dpfSlider').max = sliderMaxVal;
  document.getElementById('sliderMax').textContent = mon === 'BOB' ? 'Bs. 10M' : 'US$ 50k';

  document.getElementById('dpfPlaceholder').classList.add('hidden');
  document.getElementById('dpfResultados').classList.remove('hidden');
}

function renderFAQs() {
  var c = document.getElementById('faqContainer');
  if (!c) return;
  FAQS.forEach(function(faq, i) {
    var div = document.createElement('div');
    div.className = 'faq-item';
    div.innerHTML =
      '<button class="faq-btn" onclick="toggleFAQ('+i+')">' +
        '<span style="flex:1;padding-right:12px">'+faq.q+'</span>' +
        '<span class="faq-icon" id="fi'+i+'">' +
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#0A1F42" stroke-width="2.5">' +
            '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>' +
          '</svg>' +
        '</span>' +
      '</button>' +
      '<div class="faq-body" id="fb'+i+'"><div class="faq-body-inner">'+faq.a+'</div></div>';
    c.appendChild(div);
  });
}

function toggleFAQ(i) {
  var body = document.getElementById('fb'+i);
  var icon = document.getElementById('fi'+i);
  var isOpen = body.classList.contains('open');
  document.querySelectorAll('.faq-body').forEach(function(b){b.classList.remove('open');});
  document.querySelectorAll('.faq-icon').forEach(function(ic){ic.classList.remove('open');});
  if (!isOpen) { body.classList.add('open'); icon.classList.add('open'); }
}

function set(id, val) { var el=document.getElementById(id); if(el) el.textContent=val; }
function fmtCompact(n, mon) {
  var s = mon==='BOB'?'Bs.':'US$';
  if(n>=1000000) return s+' '+(n/1000000).toFixed(1)+'M';
  if(n>=1000)    return s+' '+(n/1000).toFixed(0)+'k';
  return s+' '+n;
}
</script>

