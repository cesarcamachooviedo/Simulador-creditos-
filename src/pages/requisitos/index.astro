---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Requisitos para Crédito | SimuladordeCreditos.com">

<style>
  .font-mono-num { font-family: 'DM Mono', 'Courier New', monospace; font-weight: 500; }
  .hero-bg  { background: linear-gradient(135deg, #060F1E 0%, #0A1F42 45%, #0D2860 100%); }
  .gold-bg  { background: linear-gradient(135deg, #D4A843 0%, #A87420 100%); }
  .card     { background: #fff; border-radius: 16px; box-shadow: 0 2px 18px rgba(10,31,66,.08); }
  .badge-gold { background: rgba(212,168,67,.14); border: 1px solid rgba(212,168,67,.40); color: #A87420; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; letter-spacing: .04em; }
  .doc-item { transition: background-color 0.2s, border-color 0.2s; cursor: pointer; user-select: none; }
  .doc-item.done { background-color: #F0FDF4 !important; border-color: #86EFAC !important; }
  .doc-item.done .doc-title { color: #166534 !important; text-decoration: line-through; opacity: 0.85; }
  .doc-item.done .doc-desc  { color: #16a34a !important; opacity: 0.80; }
  .check-box {
    width: 24px; height: 24px; min-width: 24px; border-radius: 8px;
    border: 2px solid #CBD5E1; background: #fff;
    display: flex; align-items: center; justify-content: center;
    transition: background-color 0.18s, border-color 0.18s, transform 0.1s; flex-shrink: 0;
  }
  .check-box:active { transform: scale(0.90); }
  .check-box.checked { background-color: #22C55E !important; border-color: #16A34A !important; }
  .check-icon { display: none; width: 14px; height: 14px; stroke: white; stroke-width: 3; fill: none; }
  .check-box.checked .check-icon { display: block; }
  #progressRing { transition: stroke-dasharray 0.35s cubic-bezier(0.4, 0, 0.2, 1); transform: rotate(-90deg); transform-origin: 50% 50%; }
  .tab-btn { transition: all 0.2s; }
  .tab-btn.active { background-color: #0A1F42; color: #ffffff; box-shadow: 0 4px 12px rgba(10,31,66,0.15); }
</style>

<section class="hero-bg text-white overflow-hidden relative">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div style="position:absolute;top:-60px;right:-60px;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,.10) 0%,transparent 70%)"></div>
    <div style="position:absolute;bottom:-80px;left:-40px;width:280px;height:280px;border-radius:50%;background:radial-gradient(circle,rgba(29,78,216,.15) 0%,transparent 70%)"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 relative">
    <div class="max-w-3xl">
      <span class="badge-gold uppercase mb-3 inline-block" style="color:#D4A843">Guía de Preparación</span>
      <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight mb-4">
        Requisitos para tu<br><span class="text-yellow-300">Crédito Bancario</span>
      </h1>
      <p class="text-blue-200 text-base sm:text-lg leading-relaxed max-w-2xl">
        Evitá observaciones y retrasos. Utilizá nuestra lista interactiva para organizar y marcar los documentos obligatorios exigidos por la normativa ASFI en Bolivia.
      </p>
    </div>
  </div>
</section>

<section class="py-12 max-w-7xl mx-auto px-4 sm:px-6">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">

    <div class="space-y-5">

      <div class="card p-6 text-center">
        <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-4">Tu Progreso</p>
        <div class="relative inline-flex items-center justify-center mb-3">
          <svg width="110" height="110" viewBox="0 0 110 110">
            <circle cx="55" cy="55" r="40" fill="none" stroke="#E2E8F0" stroke-width="9"/>
            <circle id="progressRing" cx="55" cy="55" r="40" fill="none" stroke="#22C55E" stroke-width="9"
                    stroke-linecap="round" style="stroke-dasharray:0 251.2"/>
          </svg>
          <div class="absolute text-center">
            <p class="font-mono-num text-2xl font-bold text-slate-900" id="progressPct">0%</p>
          </div>
        </div>
        <p class="font-bold text-slate-800 text-base" id="progressLabel">Sin documentos</p>
        <p class="text-slate-400 text-sm mt-1" id="progressSub">Empieza a marcar</p>
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs text-slate-400 mb-1">Documentos listos</p>
          <p class="font-mono-num text-2xl font-bold text-slate-900">
            <span id="doneCount">0</span> <span class="text-slate-400 font-normal text-lg">de</span> <span id="totalCount">0</span>
          </p>
        </div>
        <button id="btnReset" class="mt-4 text-xs text-slate-400 hover:text-red-500 transition-colors underline">
          Reiniciar checklist
        </button>
      </div>

      <div class="card p-5">
        <div class="flex gap-3 items-start">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#DBEAFE">
            <i data-lucide="lightbulb" class="w-4 h-4 text-blue-700"></i>
          </div>
          <div>
            <h4 class="font-bold text-sm text-slate-800 mb-1">Consejo Pro</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Consultá tu calificación en la Central de Riesgos ASFI antes de ir al banco. Entrá a <a href="https://asfi.gob.bo" target="_blank" class="text-yellow-600 hover:underline font-semibold">asfi.gob.bo</a> con tu CI.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-5" style="background:rgba(10,31,66,.04);border:1px solid rgba(10,31,66,.10)">
        <div class="flex gap-3 items-start">
          <div class="p-2 rounded-xl gold-bg flex-shrink-0">
            <i data-lucide="shield-check" class="w-4 h-4 text-white"></i>
          </div>
          <div>
            <h4 class="font-bold text-sm text-navy-900 mb-1">Privacidad Asegurada</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Tu progreso se guarda localmente en tu navegador. Ningún dato personal se envía a servidores externos.</p>
          </div>
        </div>
      </div>

      <a href="/" class="btn-gold flex items-center justify-center gap-2 text-sm" style="width:100%;text-decoration:none;display:flex">
        <i data-lucide="calculator" class="w-4 h-4"></i> Simular mi Crédito
      </a>
    </div>

    <div class="lg:col-span-2 space-y-5">

      <div class="flex p-1.5 gap-1 rounded-2xl" style="background:#E2E8F0">
        <button data-type="dependiente"
          class="tab-btn active flex-1 py-3 px-4 rounded-xl text-sm font-bold text-slate-600 hover:text-slate-900 whitespace-nowrap flex items-center justify-center gap-2">
          <i data-lucide="briefcase" class="w-4 h-4"></i> Asalariado / Dependiente
        </button>
        <button data-type="independiente"
          class="tab-btn flex-1 py-3 px-4 rounded-xl text-sm font-bold text-slate-600 hover:text-slate-900 whitespace-nowrap flex items-center justify-center gap-2">
          <i data-lucide="store" class="w-4 h-4"></i> Independiente / Consultor
        </button>
      </div>

      <div id="checklistContainer" class="space-y-3"></div>

    </div>
  </div>
</section>

<script>
  const dataRequisitos = {
    dependiente: [
      { id: 'dep_id',        cat: 'Identificación', title: 'Cédula de Identidad (C.I.)',            desc: 'Fotocopia vigente y legible del solicitante y cónyuge (si corresponde).' },
      { id: 'dep_aviso',     cat: 'Domicilio',       title: 'Aviso de Cobranza de Luz o Agua',       desc: 'Último mes pagado del domicilio actual (sirve para verificar la dirección exacta).' },
      { id: 'dep_croquis',   cat: 'Domicilio',       title: 'Croquis de Ubicación',                  desc: 'Dibujo detallado de la ubicación de tu domicilio y de tu fuente laboral.' },
      { id: 'dep_boletas',   cat: 'Ingresos',        title: '3 Últimas Boletas de Pago',             desc: 'Originales y firmadas/selladas por la empresa.' },
      { id: 'dep_afp',       cat: 'Ingresos',        title: 'Extracto de AFP / Gestora Pública',     desc: 'Histórico de aportes actualizado (mínimo los últimos 12 meses).' },
      { id: 'dep_banco',     cat: 'Ingresos',        title: 'Extracto Bancario — Cuenta de Sueldos', desc: 'Movimientos de los últimos 6 meses donde se refleje el abono del salario.' },
      { id: 'dep_trabajo',   cat: 'Laboral',         title: 'Certificado de Trabajo',                desc: 'Original indicando cargo, antigüedad mínima de 1 año, sueldo básico y tipo de contrato.' },
    ],
    independiente: [
      { id: 'ind_id',        cat: 'Identificación',  title: 'Cédula de Identidad (C.I.)',            desc: 'Fotocopia vigente y legible del solicitante y cónyuge (si corresponde).' },
      { id: 'ind_aviso',     cat: 'Domicilio',       title: 'Aviso de Cobranza de Luz o Agua',       desc: 'Último mes pagado de tu domicilio y del local comercial o negocio.' },
      { id: 'ind_croquis',   cat: 'Domicilio',       title: 'Croquis de Ubicación',                  desc: 'Detalle de ubicación exacto de tu residencia y del lugar del negocio.' },
      { id: 'ind_nit',       cat: 'Legal Negocio',   title: 'NIT y Certificado de Inscripción',      desc: 'Régimen General o Simplificado debidamente actualizado.' },
      { id: 'ind_licencia',  cat: 'Legal Negocio',   title: 'Licencia de Funcionamiento',            desc: 'Emitida por el Gobierno Autónomo Municipal correspondiente.' },
      { id: 'ind_impuestos', cat: 'Impuestos',       title: 'Formularios de Impuestos (IVA/IT/IUE)', desc: 'Pagos de los últimos 3 meses o última gestión anual según el régimen.' },
      { id: 'ind_extractos', cat: 'Ingresos',        title: 'Extractos Bancarios de Cuentas',        desc: 'Últimos 6 meses de cuentas personales y/o del negocio que demuestren flujo constante.' },
      { id: 'ind_respaldos', cat: 'Ingresos',        title: 'Cuadernos de Venta / Facturas / Contratos', desc: 'Documentación que respalde el movimiento diario de caja o inventarios.' },
    ],
  };

  let currentType = 'dependiente';

  document.addEventListener('DOMContentLoaded', () => {
    if (window.lucide) window.lucide.createIcons();
    renderChecklist();
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const type = e.currentTarget.getAttribute('data-type');
        if (!type || type === currentType) return;
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        e.currentTarget.classList.add('active');
        currentType = type;
        renderChecklist();
      });
    });
    document.getElementById('btnReset')?.addEventListener('click', resetChecklist);
  });

  function renderChecklist() {
    const container = document.getElementById('checklistContainer');
    if (!container) return;
    container.innerHTML = '';
    const items = dataRequisitos[currentType];
    items.forEach(item => {
      const isDone = localStorage.getItem(`req_${item.id}`) === 'true';
      const row = document.createElement('div');
      row.id        = `row_${item.id}`;
      row.className = `doc-item card p-5 border border-slate-100 flex items-start gap-4 ${isDone ? 'done' : ''}`;
      row.innerHTML = `
        <div class="mt-0.5">
          <div id="check_${item.id}" class="check-box ${isDone ? 'checked' : ''}">
            <svg class="check-icon" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[11px] font-bold uppercase tracking-wide px-2 py-0.5 bg-slate-100 rounded text-slate-500">${item.cat}</span>
          </div>
          <h4 class="doc-title font-bold text-slate-800 text-base leading-snug">${item.title}</h4>
          <p class="doc-desc text-sm text-slate-500 leading-relaxed mt-1">${item.desc}</p>
        </div>`;
      row.addEventListener('click', () => toggleItem(item.id));
      container.appendChild(row);
    });
    updateProgress();
  }

  function toggleItem(id) {
    const row = document.getElementById(`row_${id}`);
    const box = document.getElementById(`check_${id}`);
    if (!row || !box) return;
    const isDone = row.classList.contains('done');
    if (isDone) {
      row.classList.remove('done');
      box.classList.remove('checked');
      localStorage.removeItem(`req_${id}`);
    } else {
      row.classList.add('done');
      box.classList.add('checked');
      localStorage.setItem(`req_${id}`, 'true');
    }
    updateProgress();
  }

  function updateProgress() {
    const items = dataRequisitos[currentType];
    const total = items.length;
    let done = 0;
    items.forEach(item => { if (localStorage.getItem(`req_${item.id}`) === 'true') done++; });
    const pct           = total ? Math.round((done / total) * 100) : 0;
    const circumference = 2 * Math.PI * 40;
    const ring = document.getElementById('progressRing');
    if (ring) ring.style.strokeDasharray = `${(pct / 100) * circumference} ${circumference}`;
    const el = id => document.getElementById(id);
    if (el('progressPct'))   el('progressPct').textContent   = pct + '%';
    if (el('doneCount'))     el('doneCount').textContent     = done;
    if (el('totalCount'))    el('totalCount').textContent    = total;
    let label = 'Sin documentos', sub = 'Empieza a marcar tus documentos';
    if (pct > 0   && pct < 40)  { label = 'Iniciando';           sub = 'Buen comienzo, seguí reuniendo'; }
    if (pct >= 40 && pct < 70)  { label = 'En progreso';         sub = 'Ya tenés lo más importante'; }
    if (pct >= 70 && pct < 100) { label = 'Casi listo 🔥';       sub = 'Solo faltan algunos documentos'; }
    if (pct === 100)             { label = '¡Listo para el banco! 🎉'; sub = 'Tenés todo para presentar'; }
    if (el('progressLabel')) el('progressLabel').textContent = label;
    if (el('progressSub'))   el('progressSub').textContent   = sub;
  }

  function resetChecklist() {
    dataRequisitos[currentType].forEach(item => localStorage.removeItem(`req_${item.id}`));
    renderChecklist();
  }
</script>

</BaseLayout>
