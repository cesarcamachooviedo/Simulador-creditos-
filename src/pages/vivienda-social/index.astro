---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Crédito VIS Bolivia 2026 — Tasas, Requisitos y Cómo Calcular tu Cuota"
  description="Todo sobre el Crédito de Vivienda de Interés Social en Bolivia. Tasas máximas según D.S. 5403, requisitos por ingreso, monto máximo 400.000 UFV y calculadora de cuotas."
>

<style>
  .font-mono-num { font-family: 'DM Mono','Courier New',monospace; font-weight:500; }
  .hero-bg  { background: linear-gradient(135deg,#060F1E 0%,#0A1F42 45%,#0D2860 100%); }
  .gold-bg  { background: linear-gradient(135deg,#D4A843 0%,#A87420 100%); }
  .card     { background:#fff; border-radius:16px; box-shadow:0 2px 18px rgba(10,31,66,.08); }
  .badge-gold  { background:rgba(212,168,67,.14); border:1px solid rgba(212,168,67,.40); color:#A87420; font-size:11px; font-weight:700; padding:3px 10px; border-radius:20px; letter-spacing:.04em; display:inline-block; }
  .badge-green { background:#D1FAE5; color:#065F46; font-size:11px; font-weight:700; padding:4px 12px; border-radius:20px; display:inline-flex; align-items:center; gap:4px; }
  .badge-blue  { background:#DBEAFE; color:#1E40AF; font-size:11px; font-weight:700; padding:4px 12px; border-radius:20px; display:inline-flex; align-items:center; gap:4px; }
  .plan-card { border-radius:20px; overflow:hidden; transition:transform .25s,box-shadow .25s; position:relative; }
  .plan-card:hover { transform:translateY(-6px); box-shadow:0 20px 48px rgba(10,31,66,.20); }
  .plan-featured { transform:scale(1.03); box-shadow:0 12px 40px rgba(10,31,66,.22); }
  .plan-featured:hover { transform:scale(1.03) translateY(-5px); }
  .plan-badge { position:absolute; top:16px; right:16px; }
  .chk-item  { display:flex; align-items:flex-start; gap:10px; padding:9px 0; border-bottom:1px solid #F0F4FB; }
  .chk-item:last-child { border-bottom:none; }
  .chk-icon  { width:20px; height:20px; border-radius:50%; background:#D1FAE5; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
  .cross-icon{ width:20px; height:20px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
  .cmp-tbl { width:100%; border-collapse:separate; border-spacing:0; font-size:13px; }
  .cmp-tbl th { padding:12px 16px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; }
  .cmp-tbl td { padding:12px 16px; border-bottom:1px solid #EDF2F9; }
  .cmp-tbl tbody tr:last-child td { border-bottom:none; }
  .cmp-tbl tbody tr:hover td { background:#F7FAFF; }
  .inp { width:100%; padding:10px 13px; border:1.5px solid #D1DCF0; border-radius:10px; font-size:14px; color:#0A1F42; background:#F7FAFF; outline:none; transition:border-color .2s,box-shadow .2s; }
  .inp:focus { border-color:#D4A843; background:#fff; box-shadow:0 0 0 3px rgba(212,168,67,.15); }
  input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance:none; }
  .btn-gold-vis { background:linear-gradient(135deg,#D4A843 0%,#A87420 100%); color:#fff; font-weight:700; padding:14px 28px; border-radius:12px; border:none; cursor:pointer; font-size:14px; transition:all .2s; box-shadow:0 4px 16px rgba(212,168,67,.38); display:inline-flex; align-items:center; gap:8px; text-decoration:none; }
  .btn-gold-vis:hover { transform:translateY(-1px); box-shadow:0 7px 22px rgba(212,168,67,.50); }
  .btn-outline-vis { background:transparent; color:#0A1F42; font-weight:700; padding:14px 28px; border-radius:12px; border:2px solid #D1DCF0; cursor:pointer; font-size:14px; transition:all .2s; display:inline-flex; align-items:center; gap:8px; text-decoration:none; }
  .btn-outline-vis:hover { border-color:#D4A843; color:#A87420; }
  .btn-outline-white { background:transparent; color:white; font-weight:700; padding:14px 28px; border-radius:12px; border:2px solid rgba(255,255,255,.3); font-size:14px; transition:all .2s; display:inline-flex; align-items:center; gap:8px; text-decoration:none; }
  .btn-outline-white:hover { background:rgba(255,255,255,.10); border-color:white; }
</style>

<section class="hero-bg text-white relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div style="position:absolute;top:-80px;right:-100px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,.08) 0%,transparent 65%)"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 sm:py-24 relative">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-center gap-2 mb-5">
        <span class="badge-green"><i data-lucide="shield-check" class="w-3 h-3"></i> Ley 393 · Bolivia</span>
        <span class="badge-blue">Tasa Regulada ASFI</span>
        <span class="badge-gold uppercase">Vivienda Social</span>
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-bold leading-tight mb-5">
        Crédito de<br><span class="text-yellow-300">Vivienda de<br>Interés Social</span>
      </h1>
      <p class="text-blue-200 text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl">
        El programa estatal boliviano que te permite acceder a financiamiento para tu primera vivienda con <strong class="text-white">tasas máximas fijadas por ley</strong>, sin importar el banco que elijas.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#planes" class="btn-gold-vis">Ver los Planes VIS</a>
        <a href="/"       class="btn-outline-white">Simular Crédito VIS</a>
      </div>
    </div>
  </div>
</section>

<div class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5 grid grid-cols-2 sm:grid-cols-4 gap-4">
    <div class="text-center"><p class="font-mono-num text-2xl font-bold text-navy-900">5.5%</p><p class="text-slate-500 text-xs mt-0.5">Tasa mín. Nivel 1</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-2xl font-bold text-yellow-600">460k</p><p class="text-slate-500 text-xs mt-0.5">Máximo en UFV</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-2xl font-bold text-navy-900">30</p><p class="text-slate-500 text-xs mt-0.5">Años máx. de plazo</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-2xl font-bold text-green-600">Fija</p><p class="text-slate-500 text-xs mt-0.5">Tasa garantizada por ley</p></div>
  </div>
</div>

<section class="py-14 sm:py-20 max-w-7xl mx-auto px-4 sm:px-6">
  <div class="text-center mb-12">
    <span class="badge-gold uppercase">Elegibilidad</span>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold mt-3">¿Calificás para el VIS?</h2>
    <p class="text-slate-500 mt-2 max-w-xl mx-auto">Requisitos básicos que debés cumplir antes de aplicar a cualquier banco.</p>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

    <div class="card p-7">
      <h3 class="font-display text-2xl font-semibold mb-5 flex items-center gap-2">
        <span class="w-8 h-8 rounded-xl flex items-center justify-center" style="background:#D1FAE5">
          <i data-lucide="check-circle-2" class="w-4 h-4 text-green-700"></i>
        </span>
        Condiciones Obligatorias
      </h3>
      <div>
        <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><div><p class="font-bold text-sm text-navy-900">Primera y única vivienda</p><p class="text-slate-500 text-sm mt-0.5">No podés tener otra propiedad a tu nombre ni de tu cónyuge en Bolivia.</p></div></div>
        <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><div><p class="font-bold text-sm text-navy-900">Vivienda para habitarla vos mismo</p><p class="text-slate-500 text-sm mt-0.5">No puede ser para alquiler, oficina o actividad comercial. Declaración jurada requerida.</p></div></div>
        <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><div><p class="font-bold text-sm text-navy-900">Valor dentro de los límites UFV</p><p class="text-slate-500 text-sm mt-0.5">El inmueble no puede superar 460,000 UFV (≈ Bs. 1,097,000 al valor UFV actual).</p></div></div>
        <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><div><p class="font-bold text-sm text-navy-900">Prestatario persona natural</p><p class="text-slate-500 text-sm mt-0.5">Solo para individuos bolivianos o con residencia legal. No aplica para empresas.</p></div></div>
        <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><div><p class="font-bold text-sm text-navy-900">Solvencia crediticia</p><p class="text-slate-500 text-sm mt-0.5">Sin calificación D o E en la central de riesgos ASFI al momento de la solicitud.</p></div></div>
        <div class="mt-5 pt-4 border-t border-gray-100">
          <p class="text-sm font-bold text-red-600 mb-3 flex items-center gap-1.5"><i data-lucide="x-circle" class="w-4 h-4"></i> Casos que NO califican</p>
          <div class="space-y-2">
            <div class="flex gap-2 items-start"><div class="cross-icon mt-0.5"><i data-lucide="x" class="w-3 h-3 text-red-600"></i></div><p class="text-sm text-slate-600">Inmueble con valor superior a 460,000 UFV</p></div>
            <div class="flex gap-2 items-start"><div class="cross-icon mt-0.5"><i data-lucide="x" class="w-3 h-3 text-red-600"></i></div><p class="text-sm text-slate-600">Ya tenés otra vivienda registrada a tu nombre</p></div>
            <div class="flex gap-2 items-start"><div class="cross-icon mt-0.5"><i data-lucide="x" class="w-3 h-3 text-red-600"></i></div><p class="text-sm text-slate-600">Refinanciamiento de crédito hipotecario existente</p></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card p-7" style="border:2px solid rgba(212,168,67,.30)">
      <h3 class="font-display text-2xl font-semibold mb-1">Conversor UFV → Bolivianos</h3>
      <p class="text-slate-400 text-xs mb-5">UFV vigente: Bs. <span class="ufv-value">2.3847</span> por UFV</p>
      <div class="space-y-4">
        <div>
          <label class="text-xs font-bold uppercase tracking-wider text-slate-400 block mb-2">Valor del inmueble en UFV</label>
          <input type="number" id="ufvInput" class="inp font-mono-num text-lg" value="380000" oninput="convertUFV()">
        </div>
        <div class="rounded-2xl p-5 text-center" style="background:linear-gradient(135deg,#060F1E,#0A1F42)">
          <p class="text-blue-300 text-xs uppercase tracking-wider mb-1">Equivalente en Bolivianos</p>
          <p class="font-mono-num text-4xl font-bold text-white" id="ufvResult">Bs. 906,186</p>
          <p class="text-blue-400 text-xs mt-1" id="ufvTier">Nivel 2 · Tasa máx. 6.5%</p>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-2 mt-4">
        <button onclick="setUFV(255000)" class="py-2 px-3 rounded-xl text-sm font-bold border-2 border-gray-200 hover:border-yellow-400 hover:text-yellow-600 transition-all">255k UFV</button>
        <button onclick="setUFV(380000)" class="py-2 px-3 rounded-xl text-sm font-bold border-2 border-yellow-400 text-yellow-600 hover:bg-yellow-50 transition-all">380k UFV</button>
        <button onclick="setUFV(460000)" class="py-2 px-3 rounded-xl text-sm font-bold border-2 border-gray-200 hover:border-yellow-400 hover:text-yellow-600 transition-all">460k UFV</button>
      </div>
    </div>

  </div>
</section>

<section id="planes" class="py-14 sm:py-20" style="background:linear-gradient(135deg,#F0F4FF 0%,#EEF2FA 100%)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <span class="badge-gold uppercase">Regulación ASFI</span>
      <h2 class="font-display text-3xl sm:text-5xl font-bold mt-3">Planes de Crédito VIS</h2>
      <p class="text-slate-500 mt-3 max-w-2xl mx-auto">Las tasas son <strong>topes máximos fijados por ley</strong>. Tu banco no puede cobrarte más.</p>
    </div>
    <div class="rounded-2xl p-4 mb-10 flex items-center gap-3 max-w-lg mx-auto" style="background:rgba(212,168,67,.10);border:1px solid rgba(212,168,67,.30)">
      <i data-lucide="info" class="w-5 h-5 text-yellow-600 flex-shrink-0"></i>
      <p class="text-sm text-yellow-800">UFV actual: <strong>Bs. <span class="ufv-value">2.3847</span></strong> por UFV · Actualizado diariamente por el BCB</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">

      <div class="plan-card" style="background:white;border:2px solid #E5EDF8">
        <div class="p-7 pb-5" style="background:linear-gradient(135deg,#EEF4FF,#DBEAFE)">
          <div class="flex items-center gap-2 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#1D4ED8"><i data-lucide="home" class="w-5 h-5 text-white"></i></div><div><p class="text-xs font-bold uppercase tracking-wider text-blue-700">Nivel I</p><p class="font-display text-lg font-semibold text-navy-900">Vivienda Básica</p></div></div>
          <p class="text-slate-500 text-xs mb-1">Tasa Máxima Anual</p>
          <div class="font-mono-num text-5xl font-bold text-navy-900">5.5<span class="text-2xl">%</span></div>
          <div class="flex flex-wrap gap-1.5 mt-3"><span class="badge-green"><i data-lucide="lock" class="w-3 h-3"></i> Tasa Fija</span><span class="badge-blue">Ley 393</span></div>
        </div>
        <div class="mx-5 mt-5 rounded-2xl p-4 text-center" style="background:linear-gradient(135deg,#0A1F42,#0D2860)">
          <p class="text-blue-300 text-xs uppercase tracking-wide mb-1">Límite del Inmueble</p>
          <p class="font-mono-num text-3xl font-bold text-white">255,000 <span class="text-lg text-yellow-300">UFV</span></p>
          <p class="font-mono-num text-sm text-blue-300 mt-1">≈ Bs. 607,898</p>
        </div>
        <div class="p-5">
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Plazo hasta <strong>30 años</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Financiamiento hasta <strong>80% del valor</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Sin penalidad por <strong>pago anticipado</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">En <strong>BOB o UFV</strong></p></div>
        </div>
        <div class="px-5 pb-6"><a href="/" class="btn-outline-vis w-full justify-center" style="width:100%"><i data-lucide="calculator" class="w-4 h-4"></i> Simular Nivel I</a></div>
      </div>

      <div class="plan-card plan-featured" style="background:#0A1F42;border:2px solid #D4A843">
        <div class="plan-badge"><span class="badge-gold uppercase">⭐ Más Solicitado</span></div>
        <div class="p-7 pb-5" style="background:linear-gradient(135deg,rgba(212,168,67,.18),rgba(212,168,67,.05))">
          <div class="flex items-center gap-2 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center gold-bg"><i data-lucide="home" class="w-5 h-5 text-white"></i></div><div><p class="text-xs font-bold uppercase tracking-wider text-yellow-400">Nivel II</p><p class="font-display text-lg font-semibold text-white">Vivienda Media</p></div></div>
          <p class="text-blue-300 text-xs mb-1">Tasa Máxima Anual</p>
          <div class="font-mono-num text-5xl font-bold text-yellow-300">6.5<span class="text-2xl">%</span></div>
          <div class="flex flex-wrap gap-1.5 mt-3"><span style="background:rgba(212,168,67,.20);border:1px solid rgba(212,168,67,.50);color:#F5D98A;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;display:inline-flex;align-items:center;gap:4px"><i data-lucide="lock" class="w-3 h-3"></i> Tasa Fija</span></div>
        </div>
        <div class="mx-5 mt-5 rounded-2xl p-4 text-center gold-bg">
          <p class="text-yellow-100 text-xs uppercase tracking-wide mb-1">Límite del Inmueble</p>
          <p class="font-mono-num text-3xl font-bold text-white">380,000 <span class="text-lg">UFV</span></p>
          <p class="font-mono-num text-sm text-yellow-100 mt-1">≈ Bs. 906,186</p>
        </div>
        <div class="p-5">
          <div class="chk-item" style="border-color:rgba(255,255,255,.08)"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-blue-100">Plazo hasta <strong class="text-white">30 años</strong></p></div>
          <div class="chk-item" style="border-color:rgba(255,255,255,.08)"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-blue-100">Hasta <strong class="text-white">80% del valor</strong></p></div>
          <div class="chk-item" style="border-color:rgba(255,255,255,.08)"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-blue-100">Sin penalidad por <strong class="text-white">pago anticipado</strong></p></div>
          <div class="chk-item" style="border-color:rgba(255,255,255,.08)"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-blue-100">Disponible en <strong class="text-white">todos los bancos</strong></p></div>
          <div class="chk-item" style="border-color:rgba(255,255,255,.08)"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-blue-100">Aplica en <strong class="text-white">cualquier ciudad</strong> de Bolivia</p></div>
        </div>
        <div class="px-5 pb-6"><a href="/" class="btn-gold-vis w-full justify-center" style="width:100%;border-radius:12px"><i data-lucide="calculator" class="w-4 h-4"></i> Simular Nivel II</a></div>
      </div>

      <div class="plan-card" style="background:white;border:2px solid #E5EDF8">
        <div class="p-7 pb-5" style="background:linear-gradient(135deg,#F0FDF4,#DCFCE7)">
          <div class="flex items-center gap-2 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#15803D"><i data-lucide="building-2" class="w-5 h-5 text-white"></i></div><div><p class="text-xs font-bold uppercase tracking-wider text-green-700">Nivel III</p><p class="font-display text-lg font-semibold text-navy-900">Vivienda Superior</p></div></div>
          <p class="text-slate-500 text-xs mb-1">Tasa Máxima Anual</p>
          <div class="font-mono-num text-5xl font-bold text-navy-900">7.5<span class="text-2xl">%</span></div>
          <div class="flex flex-wrap gap-1.5 mt-3"><span class="badge-green"><i data-lucide="lock" class="w-3 h-3"></i> Tasa Fija</span><span class="badge-gold">Tope ASFI</span></div>
        </div>
        <div class="mx-5 mt-5 rounded-2xl p-4 text-center" style="background:linear-gradient(135deg,#15803D,#166534)">
          <p class="text-green-200 text-xs uppercase tracking-wide mb-1">Límite del Inmueble</p>
          <p class="font-mono-num text-3xl font-bold text-white">460,000 <span class="text-lg text-green-300">UFV</span></p>
          <p class="font-mono-num text-sm text-green-200 mt-1">≈ Bs. 1,096,962</p>
        </div>
        <div class="p-5">
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Plazo hasta <strong>30 años</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Hasta <strong>80% del valor</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">Para <strong>departamentos y casas</strong></p></div>
          <div class="chk-item"><div class="chk-icon"><i data-lucide="check" class="w-3 h-3 text-green-700"></i></div><p class="text-sm text-navy-900">En <strong>BOB o UFV</strong></p></div>
        </div>
        <div class="px-5 pb-6"><a href="/" class="btn-outline-vis w-full justify-center" style="width:100%"><i data-lucide="calculator" class="w-4 h-4"></i> Simular Nivel III</a></div>
      </div>

    </div>
  </div>
</section>

<section class="py-14 sm:py-20 max-w-5xl mx-auto px-4 sm:px-6">
  <div class="text-center mb-10">
    <span class="badge-gold uppercase">Comparativa</span>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold mt-3">VIS vs Crédito Hipotecario Normal</h2>
    <p class="text-slate-500 mt-2">¿Cuánto ahorrás realmente eligiendo el programa VIS?</p>
  </div>
  <div class="card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="cmp-tbl">
        <thead>
          <tr style="background:#F8FAFF">
            <th style="color:#4B6A9B;border-bottom:2px solid #E5EDF8;text-align:left">Característica</th>
