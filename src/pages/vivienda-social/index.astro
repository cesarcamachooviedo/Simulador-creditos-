<script is:inline>
  const UFV_VALUE = window.UFV_VIGENTE || 2.3847;
  const UFV_TIERS = [
    { max: 255000, label: 'Nivel 1 · Tasa máx. 5.5%' },
    { max: 380000, label: 'Nivel 2 · Tasa máx. 6.5%' },
    { max: 460000, label: 'Nivel 3 · Tasa máx. 7.5%' },
    { max: Infinity, label: '⚠️ Supera el límite VIS (460,000 UFV)' },
  ];
  function convertUFV() {
    const ufv = +document.getElementById('ufvInput').value || 0;
    const bs  = ufv * UFV_VALUE;
    document.getElementById('ufvResult').textContent = 'Bs. ' + bs.toLocaleString('es-BO', { maximumFractionDigits: 0 });
    const tier   = UFV_TIERS.find(t => ufv <= t.max);
    const tierEl = document.getElementById('ufvTier');
    tierEl.textContent = tier.label;
    tierEl.style.color = tier.max === Infinity ? '#F87171' : '#93C5FD';
  }
  function setUFV(val) {
    document.getElementById('ufvInput').value = val;
    convertUFV();
  }
  document.addEventListener('DOMContentLoaded', convertUFV);
</script>

