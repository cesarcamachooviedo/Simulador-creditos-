<script is:inline>
"use strict";
var MICRO_DOCS = [
  { id:'mi_ci',       grupo:'Identidad', title:'Cédula de Identidad vigente', desc:'Fotocopia anverso y reverso. Original para cotejo en el banco.' },
  { id:'mi_croquis',  grupo:'Identidad', title:'Croquis de ubicación del negocio', desc:'Dibujo de la ubicación exacta del local. El asesor lo usa para la visita.' },
  { id:'mi_aviso',    grupo:'Identidad', title:'Aviso de cobranza de luz o agua', desc:'Último mes pagado del domicilio o del local comercial.' },
  { id:'mi_nit',      grupo:'Legal', title:'NIT activo (Impuestos Nacionales)', desc:'Imprimí el QR de verificación desde impuestos.gob.bo. Debe estar vigente.' },
  { id:'mi_licencia', grupo:'Legal', title:'Licencia de funcionamiento municipal', desc:'Emitida por el Gobierno Municipal correspondiente. Vigente al año actual.' },
  { id:'mi_cuaderno', grupo:'Ingresos', title:'Cuaderno de ventas (mínimo 3 meses)', desc:'Registros de ingresos diarios o semanales. El principal respaldo de tus ingresos.' },
  { id:'mi_facturas', grupo:'Ingresos', title:'Facturas o recibos de compra/venta', desc:'Documentos de transacciones del negocio. Refuerzan el flujo de caja declarado.' },
  { id:'mi_extracto', grupo:'Ingresos', title:'Extracto bancario (si tenés cuenta)', desc:'Últimos 3 a 6 meses. Muestra que los ingresos se depositan regularmente.' },
  { id:'mi_impuesto', grupo:'Impuestos', title:'Formularios de IVA o IT (últimos 3)', desc:'Si estás en Régimen General. En Régimen Simplificado no aplica.' },
  { id:'mi_solicitud', grupo:'Banco', title:'Formulario de solicitud del banco', desc:'Cada banco tiene el suyo. Pedílo en sucursal o descargalo de su web.' },
  { id:'mi_foto',     grupo:'Banco', title:'Fotografías del local y mercadería', desc:'Algunos bancos las piden antes de la visita. Tomá fotos actualizadas del negocio.' },
];

function renderMicroChecklist() {
  var container = document.getElementById('microChkContainer');
  if (!container) return;
  var grupos = {};
  MICRO_DOCS.forEach(function(d) { if (!grupos[d.grupo]) grupos[d.grupo] = []; grupos[d.grupo].push(d); });
  var html = '';
  Object.keys(grupos).forEach(function(g) {
    html += '<p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#94A3B8;margin:16px 0 8px;padding:0 4px;">' + g + '</p>';
    grupos[g].forEach(function(doc) {
      var isDone = localStorage.getItem('micro_' + doc.id) === 'true';
      html += '<div class="chk-item ' + (isDone ? 'done' : '') + '" id="mrow_' + doc.id + '" onclick="toggleMicro(\'' + doc.id + '\')">' +
        '<div class="chk-box"><svg class="chk-mark" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>' +
        '<div style="flex:1;min-width:0;"><p class="chk-title">' + doc.title + '</p><p class="chk-desc">' + doc.desc + '</p></div>' +
      '</div>';
    });
  });
  container.innerHTML = html;
  updateMicroProgress();
}

function toggleMicro(id) {
  var row = document.getElementById('mrow_' + id);
  var isDone = row.classList.contains('done');
  if (isDone) { row.classList.remove('done'); localStorage.removeItem('micro_' + id); }
  else { row.classList.add('done'); localStorage.setItem('micro_' + id, 'true'); }
  updateMicroProgress();
}

function updateMicroProgress() {
  var total = MICRO_DOCS.length;
  var done  = MICRO_DOCS.filter(function(d) { return localStorage.getItem('micro_' + d.id) === 'true'; }).length;
  var pct   = total ? Math.round((done / total) * 100) : 0;
  var circ  = 2 * Math.PI * 40;
  var ring  = document.getElementById('chkRing');
  if (ring) ring.style.strokeDasharray = (pct / 100 * circ) + ' ' + circ;
  var s = function(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; };
  s('chkPct', pct + '%'); s('chkDone', done); s('chkTotal', total);
  var label = 'Sin documentos', sub = 'Empezá a marcar';
  if (pct > 0   && pct < 40)  { label = 'Iniciando';           sub = 'Seguí reuniendo documentos'; }
  if (pct >= 40 && pct < 70)  { label = 'En progreso';         sub = 'Ya tenés lo esencial'; }
  if (pct >= 70 && pct < 100) { label = 'Casi listo 🔥';       sub = 'Faltan pocos documentos'; }
  if (pct === 100)             { label = 'Listo para el banco!'; sub = 'Tenés todo lo necesario'; }
  s('chkLabel', label); s('chkSub', sub);
}

document.addEventListener('DOMContentLoaded', function() {
  renderMicroChecklist();
  var btn = document.getElementById('btnChkReset');
  if (btn) btn.addEventListener('click', function() {
    MICRO_DOCS.forEach(function(d) { localStorage.removeItem('micro_' + d.id); });
    renderMicroChecklist();
  });
});
</script>

