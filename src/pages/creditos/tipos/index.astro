function mostrarRecomendacion(tipo, btn) {
  var r = RECOMENDACIONES[tipo];
  if (!r) return;
  document.querySelectorAll('.decision-btn').forEach(function(b) { b.classList.remove('selected'); });
  btn.classList.add('selected');
  document.getElementById('recIcon').textContent      = r.icon;
  document.getElementById('recTitulo').textContent    = r.titulo;
  document.getElementById('recDesc').textContent      = r.desc;
  document.getElementById('recLink1').href            = r.link1;
  document.getElementById('recLink1Text').textContent = r.link1Text;
  document.getElementById('recLink2').href            = r.link2;
  document.getElementById('recLink2Text').textContent = r.link2Text;
  var rec = document.getElementById('recomendacion');
  rec.classList.remove('hidden');
  rec.scrollIntoView({ behavior:'smooth', block:'nearest' });
}
</script>

