---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tipos de Crédito en Bolivia 2026 — ¿Cuál te Conviene? Guía Completa"
  description="Guía completa de los tipos de crédito disponibles en Bolivia: hipotecario VIS, vehicular, personal, comercial y microcrédito. Comparativa de tasas, plazos y requisitos según normativa ASFI 2026."
>

<style>
  .hero-bg { background:linear-gradient(135deg,#060F1E 0%,#0A1F42 45%,#0D2860 100%); }
  .gold-bg  { background:linear-gradient(135deg,#D4A843 0%,#A87420 100%); }
  .card     { background:#fff; border-radius:16px; box-shadow:0 2px 18px rgba(10,31,66,.08); }
  .font-mono-num { font-family:'DM Mono','Courier New',monospace; font-weight:500; }
  .badge-gold   { background:rgba(212,168,67,.14);border:1px solid rgba(212,168,67,.40);color:#A87420;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .badge-green  { background:#D1FAE5;color:#065F46;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .badge-blue   { background:#DBEAFE;color:#1E40AF;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .badge-purple { background:#EDE9FE;color:#5B21B6;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .badge-orange { background:#FFEDD5;color:#9A3412;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block; }
  .credit-card { border-radius:20px;overflow:hidden;border:2px solid #E5EDF8;background:#fff;transition:transform .25s,box-shadow .25s,border-color .25s;display:flex;flex-direction:column; }
  .credit-card:hover { transform:translateY(-5px);box-shadow:0 14px 40px rgba(10,31,66,.14);border-color:#D4A843; }
  .rate-pill { font-family:'DM Mono',monospace;font-size:13px;font-weight:700;padding:4px 12px;border-radius:20px;display:inline-block; }
  .rate-low  { background:#D1FAE5;color:#065F46; }
  .rate-mid  { background:#DBEAFE;color:#1E40AF; }
  .rate-high { background:#FEE2E2;color:#991B1B; }
  .cmp-tbl { width:100%;border-collapse:separate;border-spacing:0;font-size:13px; }
  .cmp-tbl thead th { padding:12px 14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em; }
  .cmp-tbl thead th:first-child { text-align:left; }
  .cmp-tbl td { padding:12px 14px;border-bottom:1px solid #EDF2F9; }
  .cmp-tbl td:first-child { font-weight:600;color:#4B6A9B; }
  .cmp-tbl tbody tr:last-child td { border-bottom:none; }
  .cmp-tbl tbody tr:hover td { background:#F7FAFF; }
  .decision-btn { width:100%;padding:14px 18px;border-radius:12px;border:1.5px solid #E5EDF8;background:#fff;cursor:pointer;text-align:left;font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:600;color:#0A1F42;transition:all .2s;display:flex;align-items:center;gap:12px; }
  .decision-btn:hover { border-color:#D4A843;background:#FFFDF5; }
  .decision-btn.selected { border-color:#0A1F42;background:#0A1F42;color:#fff; }
</style>

<section class="hero-bg text-white relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div style="position:absolute;top:-60px;right:-80px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(212,168,67,.09) 0%,transparent 70%)"></div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 relative">
    <div class="max-w-3xl">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="badge-gold uppercase">Guía Completa 2026</span>
        <span class="badge-green">Normativa ASFI</span>
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight mb-4">
        Tipos de Crédito<br><span class="text-yellow-300">en Bolivia</span><br>¿Cuál te conviene?
      </h1>
      <p class="text-blue-200 text-base sm:text-lg leading-relaxed max-w-2xl">
        El sistema financiero boliviano ofrece distintos tipos de crédito según tu propósito, ingresos y garantías. Entendé las diferencias antes de ir al banco para elegir el que mejor se adapta a tu situación.
      </p>
    </div>
  </div>
</section>

<div class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 grid grid-cols-2 sm:grid-cols-5 gap-4">
    <div class="text-center"><p class="font-mono-num text-lg font-bold text-navy-900">5.5%</p><p class="text-slate-500 text-xs mt-0.5">Tasa mín. VIS</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-lg font-bold text-yellow-600">30 años</p><p class="text-slate-500 text-xs mt-0.5">Plazo máx. hipotecario</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-lg font-bold text-green-600">25%</p><p class="text-slate-500 text-xs mt-0.5">Límite cuota/ingreso</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-lg font-bold text-navy-900">0%</p><p class="text-slate-500 text-xs mt-0.5">Penalidad prepago</p></div>
    <div class="text-center border-l border-gray-100"><p class="font-mono-num text-lg font-bold text-purple-600">ASFI</p><p class="text-slate-500 text-xs mt-0.5">Ente regulador</p></div>
  </div>
</div>

<section class="py-12 sm:py-14 max-w-4xl mx-auto px-4 sm:px-6">
  <div class="text-center mb-8">
    <span class="badge-gold uppercase">Herramienta interactiva</span>
    <h2 class="font-display text-3xl font-semibold mt-3">¿Para qué necesitás el crédito?</h2>
    <p class="text-slate-500 mt-2">Respondé esta pregunta y te mostramos el tipo de crédito que más te conviene.</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
    <button class="decision-btn" onclick="mostrarRecomendacion('vivienda',this)">
      <span style="font-size:28px;">🏠</span>
      <div><p style="margin:0;font-size:15px;">Comprar mi primera vivienda</p><p style="margin:0;font-size:12px;opacity:.6;font-weight:400;">Casa o departamento para vivir</p></div>
    </button>
    <button class="decision-btn" onclick="mostrarRecomendacion('vehiculo',this)">
      <span style="font-size:28px;">🚗</span>
      <div><p style="margin:0;font-size:15px;">Comprar un vehículo</p><p style="margin:0;font-size:12px;opacity:.6;font-weight:400;">Auto nuevo o usado</p></div>
    </button>
    <button class="decision-btn" onclick="mostrarRecomendacion('negocio',this)">
      <span style="font-size:28px;">🏪</span>
      <div><p style="margin:0;font-size:15px;">Capital para mi negocio</p><p style="margin:0;font-size:12px;opacity:.6;font-weight:400;">Emprendedor o independiente</p></div>
    </button>
    <button class="decision-btn" onclick="mostrarRecomendacion('personal',this)">
      <span style="font-size:28px;">👤</span>
      <div><p style="margin:0;font-size:15px;">Gastos personales o emergencia</p><p style="margin:0;font-size:12px;opacity:.6;font-weight:400;">Educación, salud, viaje, etc.</p></div>
    </button>
  </div>
  <div id="recomendacion" class="hidden rounded-2xl p-6" style="background:linear-gradient(135deg,#0A1F42,#0D2860);border:1px solid rgba(212,168,67,.3);">
    <div class="flex items-start gap-4">
      <div id="recIcon" class="text-4xl flex-shrink-0"></div>
      <div class="flex-1">
        <p class="text-yellow-300 text-xs font-bold uppercase tracking-widest mb-1">Recomendación para tu caso</p>
        <h3 id="recTitulo" class="font-display text-2xl font-bold text-white mb-2"></h3>
        <p id="recDesc" class="text-blue-200 text-sm leading-relaxed mb-4"></p>
        <div class="flex flex-wrap gap-3">
          <a id="recLink1" href="#" style="background:linear-gradient(135deg,#D4A843,#A87420);color:#fff;font-weight:700;padding:10px 20px;border-radius:10px;text-decoration:none;font-size:13px;display:inline-flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
            <span id="recLink1Text"></span>
          </a>
          <a id="recLink2" href="#" style="background:transparent;color:white;font-weight:700;padding:10px 20px;border-radius:10px;text-decoration:none;font-size:13px;border:1.5px solid rgba(255,255,255,.3);">
            <span id="recLink2Text"></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-12 sm:py-16 max-w-7xl mx-auto px-4 sm:px-6">
  <div class="text-center mb-12">
    <span class="badge-gold uppercase">Catálogo completo</span>
    <h2 class="font-display text-3xl sm:text-4xl font-semibold mt-3">Los 5 tipos de crédito en Bolivia</h2>
    <p class="text-slate-500 mt-2 max-w-xl mx-auto">Cada tipo tiene sus propias tasas, plazos y condiciones reguladas por la ASFI.</p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

    <div class="credit-card" style="border-color:#D4A843;">
      <div class="p-6 pb-4" style="background:linear-gradient(135deg,#0A1F42,#0D2860);">
        <div class="flex items-center justify-between mb-3">
          <div class="w-12 h-12 rounded-2xl gold-bg flex items-center justify-center"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <span style="background:rgba(212,168,67,.2);border:1px solid rgba(212,168,67,.5);color:#FDE047;font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;">MAS CONVENIENTE</span>
        </div>
        <h3 class="font-display text-xl font-bold text-white mb-1">Crédito Vivienda Social</h3>
        <p class="text-blue-300 text-xs">VIS — Ley 393 Bolivia</p>
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <div><p class="text-xs text-slate-400 mb-1">Tasa máxima (fija por ley)</p><p class="font-mono-num text-2xl font-bold text-yellow-600">5.5% – 7.5%</p></div>
          <div class="text-right"><p class="text-xs text-slate-400 mb-1">Plazo máximo</p><p class="font-mono-num text-2xl font-bold text-navy-900">30 años</p></div>
        </div>
        <div class="space-y-2 text-sm mb-5">
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Tasa <strong>fija y garantizada</strong> por ley</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Sin penalidad por pago anticipado</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Para primera y única vivienda</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><span class="text-slate-600">Límite: inmueble hasta 460,000 UFV</span></div>
        </div>
        <div class="mt-auto space-y-2">
          <a href="/vivienda-social" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;background:linear-gradient(135deg,#D4A843,#A87420);color:#fff;">Ver guía completa del VIS</a>
          <a href="/" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;border:1.5px solid #E5EDF8;color:#0A1F42;">Simular cuota</a>
        </div>
      </div>
    </div>

    <div class="credit-card">
      <div class="p-6 pb-4" style="background:linear-gradient(135deg,#EEF4FF,#DBEAFE);">
        <div class="flex items-center justify-between mb-3">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center" style="background:#1D4ED8;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
          <span class="badge-blue">Consumo</span>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Crédito Vehicular</h3>
        <p class="text-blue-500 text-xs">Auto nuevo o usado</p>
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <div><p class="text-xs text-slate-400 mb-1">Tasa referencial anual</p><p class="font-mono-num text-2xl font-bold text-blue-700">8% – 14%</p></div>
          <div class="text-right"><p class="text-xs text-slate-400 mb-1">Plazo máximo</p><p class="font-mono-num text-2xl font-bold text-navy-900">7 años</p></div>
        </div>
        <div class="space-y-2 text-sm mb-5">
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Hasta 90% del valor del vehículo</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Garantía: el propio vehículo</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Aprobación en 5-10 días hábiles</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="3"><path d="M12 8v4m0 4h.01"/></svg></span><span class="text-slate-600">Tasa variable: TRE + spread bancario</span></div>
        </div>
        <div class="mt-auto space-y-2">
          <a href="/" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;background:#0A1F42;color:#fff;">Simular cuota vehicular</a>
          <a href="/requisitos" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;border:1.5px solid #E5EDF8;color:#0A1F42;">Ver requisitos</a>
        </div>
      </div>
    </div>

    <div class="credit-card">
      <div class="p-6 pb-4" style="background:linear-gradient(135deg,#F5F3FF,#EDE9FE);">
        <div class="flex items-center justify-between mb-3">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center" style="background:#7C3AED;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
          <span class="badge-purple">Consumo</span>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Crédito Personal</h3>
        <p class="text-purple-500 text-xs">Educación, salud, viaje, emergencias</p>
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <div><p class="text-xs text-slate-400 mb-1">Tasa referencial anual</p><p class="font-mono-num text-2xl font-bold text-purple-700">10% – 18%</p></div>
          <div class="text-right"><p class="text-xs text-slate-400 mb-1">Plazo máximo</p><p class="font-mono-num text-2xl font-bold text-navy-900">5 años</p></div>
        </div>
        <div class="space-y-2 text-sm mb-5">
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Sin garantía hipotecaria</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Aprobación rápida (2-5 días)</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Uso libre del dinero</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><span class="text-slate-600">Tasa más alta — montos menores</span></div>
        </div>
        <div class="mt-auto space-y-2">
          <a href="/" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;background:#7C3AED;color:#fff;">Simular cuota personal</a>
          <a href="/requisitos" style="display:block;text-align:center;padding:11px;border-radius:10px;font-weight:700;font-size:13px;text-decoration:none;border:1.5px solid #E5EDF8;color:#0A1F42;">Ver requisitos</a>
        </div>
      </div>
    </div>

    <div class="credit-card">
      <div class="p-6 pb-4" style="background:linear-gradient(135deg,#FFFBEB,#FEF3C7);">
        <div class="flex items-center justify-between mb-3">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center" style="background:#D97706;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <span class="badge-orange">Productivo</span>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Microcrédito</h3>
        <p class="text-yellow-700 text-xs">Para emprendedores e independientes</p>
      </div>
      <div class="p-6 flex-1 flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <div><p class="text-xs text-slate-400 mb-1">Monto típico</p><p class="font-mono-num text-2xl font-bold text-yellow-700">Hasta Bs. 70k</p></div>
          <div class="text-right"><p class="text-xs text-slate-400 mb-1">Plazo máximo</p><p class="font-mono-num text-2xl font-bold text-navy-900">5 años</p></div>
        </div>
        <div class="space-y-2 text-sm mb-5">
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Sin boletas de sueldo ni contabilidad formal</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Evaluación por flujo de caja del negocio</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></span><span class="text-slate-600">Garantía prendaria o personal</span></div>
          <div class="flex items-center gap-2"><span class="w-4 h-4 rounded-full bg-yellow-100 flex items-center justify-center flex-shrink-0"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="3"><path d="M12 8v4m0 4h.01"/></svg></span><span class="text-slate-600">El negocio debe tener mínimo 1 año</span></div>
        </div>
